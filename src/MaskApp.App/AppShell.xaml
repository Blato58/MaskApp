<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="MaskApp.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource PageBackgroundColor}"
    Shell.ForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarBackgroundColor="{StaticResource SurfaceColor}"
    Shell.TabBarForegroundColor="{StaticResource AccentColor}"
    Shell.TabBarTitleColor="{StaticResource AccentColor}"
    Shell.TabBarUnselectedColor="{StaticResource SecondaryTextColor}"
    Shell.TitleColor="{StaticResource PrimaryTextColor}">
</Shell>
