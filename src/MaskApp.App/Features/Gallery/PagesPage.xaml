<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.PagesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:Name="RootPage"
    x:DataType="gallery:PagesViewModel"
    Title="Pages"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid>
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Grid Padding="18,16,18,8" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pages" Style="{StaticResource PageTitleLabelStyle}" />
                        <Label Text="One tap during the show. Prepare custom items beforehand." Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                    <ActivityIndicator
                        Grid.Column="1"
                        IsRunning="{Binding IsSending}"
                        IsVisible="{Binding IsSending}"
                        VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Use" Command="{Binding SetUseModeCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsUseMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlueColor}" />
                                <Setter Property="BorderColor" Value="#7AB0FF" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="1" Text="Manage" Command="{Binding SetManageModeCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsManageMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlueColor}" />
                                <Setter Property="BorderColor" Value="#7AB0FF" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Grid>

            <CollectionView
                Grid.Row="1"
                Margin="18,0,18,10"
                HeightRequest="54"
                ItemsSource="{Binding Pages}"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="gallery:GalleryPageTab">
                        <Button
                            Text="{Binding TabLabel}"
                            BorderColor="{Binding ColorHex}"
                            Command="{Binding SelectCommand}"
                            Padding="16,10"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="2">
                <CollectionView
                    x:Name="ShortcutsView"
                    Margin="14,0,14,8"
                    IsVisible="{Binding IsUseMode}"
                    ItemsSource="{Binding Shortcuts}"
                    Scrolled="OnShortcutsScrolled"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="28" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="No shortcuts yet" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Text="Open Manage and add the items you want on stage." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="gallery:GalleryPageShortcutCard">
                            <Grid Margin="4" MinimumHeightRequest="150">
                                <Border
                                    Padding="9"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    Stroke="{Binding ColorHex}"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid RowDefinitions="76,Auto,Auto" RowSpacing="6">
                                    <Border BackgroundColor="{Binding ColorHex}" HeightRequest="72" WidthRequest="72" HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="17" />
                                        </Border.StrokeShape>
                                        <Grid Padding="6">
                                            <Image
                                                Source="{Binding IconAsset}"
                                                Aspect="AspectFit"
                                                HeightRequest="34"
                                                WidthRequest="34"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding HasAnyPreview, Converter={StaticResource InvertedBoolConverter}}" />
                                            <controls:BuiltInPreviewView
                                                IsAnimationPlaying="{Binding IsAnimationPlaying}"
                                                IsVisible="{Binding HasPreview}"
                                                SemanticDescription="{Binding Label, StringFormat='{0} preview'}"
                                                Source="{Binding PreviewResourceName}" />
                                            <controls:FacePatternPreviewView
                                                IsVisible="{Binding HasFacePreview}"
                                                Pattern="{Binding FacePattern}"
                                                SemanticDescription="{Binding Label, StringFormat='{0} face preview'}" />
                                        </Grid>
                                    </Border>
                                    <Label
                                        Grid.Row="1"
                                        Text="{Binding Label}"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1" />
                                    <Label
                                        Grid.Row="2"
                                        Text="{Binding FastSlotStatusText}"
                                        TextColor="{Binding FastSlotStatusColorHex}"
                                        FontSize="11"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1" />
                                    </Grid>
                                </Border>
                                <Button
                                    Text=""
                                    Command="{Binding SendCommand}"
                                    BackgroundColor="Transparent"
                                    BorderColor="Transparent"
                                    BorderWidth="0"
                                    Padding="0"
                                    SemanticProperties.Description="{Binding Label}"
                                    SemanticProperties.Hint="{Binding UseActionText}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView
                    Margin="18,0,18,8"
                    IsVisible="{Binding IsManageMode}"
                    ItemsSource="{Binding Shortcuts}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="28" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="Build this page" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Text="Add Library items, then prepare text and DIY faces for instant playback." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="gallery:GalleryPageShortcutCard">
                            <Border Style="{StaticResource ActionCardBorderStyle}" Padding="4,14">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="64,*" ColumnSpacing="12" RowSpacing="10">
                                    <Border BackgroundColor="{Binding ColorHex}" HeightRequest="58" WidthRequest="58" VerticalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Grid Padding="5">
                                            <Image
                                                Source="{Binding IconAsset}"
                                                Aspect="AspectFit"
                                                HeightRequest="30"
                                                WidthRequest="30"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding HasAnyPreview, Converter={StaticResource InvertedBoolConverter}}" />
                                            <controls:BuiltInPreviewView
                                                IsAnimationPlaying="False"
                                                IsVisible="{Binding HasPreview}"
                                                SemanticDescription="{Binding Label, StringFormat='{0} preview'}"
                                                Source="{Binding PreviewResourceName}" />
                                            <controls:FacePatternPreviewView
                                                IsVisible="{Binding HasFacePreview}"
                                                Pattern="{Binding FacePattern}"
                                                SemanticDescription="{Binding Label, StringFormat='{0} face preview'}" />
                                        </Grid>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding Label}" FontAttributes="Bold" FontSize="17" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" />
                                        <Label Text="{Binding FastSlotStatusText}" TextColor="{Binding FastSlotStatusColorHex}" FontSize="12" />
                                    </VerticalStackLayout>

                                    <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="2*,*,*,*" ColumnSpacing="6">
                                        <Button
                                            Text="{Binding PrepareActionText}"
                                            Command="{Binding PrepareCommand}"
                                            IsVisible="{Binding IsFastSlotCapable}"
                                            Style="{StaticResource BrightButtonStyle}"
                                            Padding="8,8" />
                                        <Button
                                            Text="Show"
                                            Command="{Binding SendCommand}"
                                            IsVisible="{Binding IsFastSlotCapable, Converter={StaticResource InvertedBoolConverter}}"
                                            Style="{StaticResource NeonBlueButtonStyle}"
                                            Padding="8,8" />
                                        <Button Grid.Column="1" Text="↑" Command="{Binding MoveEarlierCommand}" Padding="6,8" SemanticProperties.Description="Move earlier" />
                                        <Button Grid.Column="2" Text="↓" Command="{Binding MoveLaterCommand}" Padding="6,8" SemanticProperties.Description="Move later" />
                                        <Button Grid.Column="3" Text="−" Command="{Binding RemoveCommand}" Padding="6,8" Style="{StaticResource DangerButtonStyle}" SemanticProperties.Description="Remove shortcut" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Border Grid.Row="3" Margin="18,0,18,16" Style="{StaticResource CompactPanelBorderStyle}" Stroke="{Binding SelectedPageColorHex}" StrokeThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding SelectedPageTitle}" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding PageReadinessText}" Style="{StaticResource TinyLabelStyle}" />
                            <Label Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" MaxLines="2" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="{Binding PagePositionText}" Style="{StaticResource TinyLabelStyle}" VerticalOptions="Center" />
                    </Grid>

                    <Grid Grid.Row="1" IsVisible="{Binding IsManageMode}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                        <Button Text="Add shortcut" Clicked="OnAddItemsClicked" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Prepare page" Command="{Binding PreparePageCommand}" Style="{StaticResource BrightButtonStyle}" />
                        <Button Grid.Row="1" Text="New page" Command="{Binding AddPageCommand}" />
                        <Button Grid.Row="1" Grid.Column="1" Text="Page settings" Command="{Binding TogglePageEditorSheetCommand}" />
                    </Grid>
                    <Label
                        Grid.Row="2"
                        IsVisible="{Binding IsManageMode}"
                        Text="Fast slots are static snapshots remembered for the last prepared mask. Refresh them after switching masks."
                        Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsPageEditorSheetVisible}" BackgroundColor="#B3000000" Padding="18">
            <Border Style="{StaticResource PanelBorderStyle}" VerticalOptions="End">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Page settings" Style="{StaticResource ModeTitleLabelStyle}" />
                            <Label Text="Rename, recolor, or reorder this page." Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Done" Command="{Binding CloseSheetsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>
                    <Entry Grid.Row="1" Placeholder="Page name" Text="{Binding PageTitleDraft, Mode=TwoWay}" />
                    <Button Grid.Row="2" Text="Save name" Command="{Binding SavePageTitleCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button Text="← Page" Command="{Binding MoveSelectedPageEarlierCommand}" />
                        <Button Grid.Column="1" Text="Color" Command="{Binding CyclePageColorCommand}" />
                        <Button Grid.Column="2" Text="Page →" Command="{Binding MoveSelectedPageLaterCommand}" />
                    </Grid>
                    <Button Grid.Row="4" Text="Delete page" Command="{Binding RemovePageCommand}" Style="{StaticResource DangerButtonStyle}" />
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsDeletePageConfirmationVisible}" BackgroundColor="#B3000000" Padding="18">
            <Border Style="{StaticResource PanelBorderStyle}" VerticalOptions="End">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="{Binding DeletePagePrompt}" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Row="1" Text="Only the page layout is removed. Library items and mask slots stay available." Style="{StaticResource MutedLabelStyle}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Cancel" Command="{Binding CloseSheetsCommand}" />
                        <Button Grid.Column="1" Text="Delete page" Command="{Binding ConfirmRemovePageCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
