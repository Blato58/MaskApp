<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.PagesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:Name="RootPage"
    x:DataType="gallery:PagesViewModel"
    Title="Pages"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Margin="18,18,18,10" Style="{StaticResource PanelBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pages" Style="{StaticResource PageTitleLabelStyle}" />
                        <Label Text="{Binding PagePositionText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                    <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsSending}" IsVisible="{Binding IsSending}" VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Use" Command="{Binding SetUseModeCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1" Text="Manage" Command="{Binding SetManageModeCommand}" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" IsVisible="{Binding IsManageMode}">
                    <Button Text="+ Page" Command="{Binding AddPageCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1" Text="Add Items" Command="{Binding ToggleAddItemsSheetCommand}" />
                    <Button Grid.Column="2" Text="Edit Page" Command="{Binding TogglePageEditorSheetCommand}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="18,0,18,10" Style="{StaticResource CompactPanelBorderStyle}">
            <CollectionView ItemsSource="{Binding Pages}" SelectionMode="None" HeightRequest="52">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="gallery:GalleryPageTab">
                        <Button
                            Text="{Binding Title}"
                            BorderColor="{Binding ColorHex}"
                            Command="{Binding SelectCommand}"
                            Style="{StaticResource NeonBlueButtonStyle}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Border Grid.Row="2" Margin="18,0,18,10" Style="{StaticResource PanelBorderStyle}" Stroke="{Binding SelectedPageColorHex}">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding SelectedPageTitle}" FontSize="28" FontAttributes="Bold" />
                        <Label Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                    <Button
                        Grid.Column="1"
                        Text="Delete"
                        Command="{Binding RemovePageCommand}"
                        IsVisible="{Binding IsManageMode}"
                        Style="{StaticResource DangerButtonStyle}" />
                </Grid>

                <CollectionView Grid.Row="1" ItemsSource="{Binding Shortcuts}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Grid Padding="18">
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                <Label Text="This page is empty" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="Use Manage to add Library items." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="gallery:GalleryPageShortcutCard">
                            <VerticalStackLayout Margin="0,0,8,16" Spacing="6">
                                <Grid>
                                    <Border
                                        BackgroundColor="{Binding ColorHex}"
                                        HeightRequest="82"
                                        Stroke="{Binding ColorHex}"
                                        WidthRequest="82"
                                        HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Grid RowDefinitions="*,Auto" Padding="6">
                                            <Label Text="{Binding IconLabel}" TextColor="#05070D" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Row="1" Text="{Binding Label}" TextColor="#05070D" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />
                                        </Grid>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SendCommand}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Button
                                        Text="-"
                                        Command="{Binding RemoveCommand}"
                                        IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.IsManageMode}"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        Padding="0"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        Style="{StaticResource DangerButtonStyle}" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="4" IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.IsManageMode}">
                                    <Button Text="Up" Command="{Binding MoveEarlierCommand}" Padding="6,4" />
                                    <Button Grid.Column="1" Text="Down" Command="{Binding MoveLaterCommand}" Padding="6,4" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="4" IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.IsManageMode}">
                                    <Button Text="Icon" Command="{Binding CycleIconCommand}" Padding="6,4" />
                                    <Button Grid.Column="1" Text="Color" Command="{Binding CycleColorCommand}" Padding="6,4" />
                                </Grid>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Button
                        Text="+ Add"
                        Command="{Binding ToggleAddItemsSheetCommand}"
                        IsVisible="{Binding IsManageMode}" />
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Pages}" SelectionMode="None" HorizontalOptions="Center" HeightRequest="42">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:GalleryPageTab">
                                <Button Text="{Binding DotText}" Command="{Binding SelectCommand}" Padding="8,4" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Border Margin="18,8,18,18" IsVisible="{Binding IsAddItemsSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Add Items to Page" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Button Grid.Column="1" Text="Done" Command="{Binding CloseSheetsCommand}" />
                    </Grid>
                    <CollectionView Grid.Row="1" HeightRequest="220" ItemsSource="{Binding AvailableItems}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:GalleryAvailableItemCard">
                                <Border Margin="0,0,8,8" Style="{StaticResource ActionCardBorderStyle}" Stroke="{Binding ColorHex}">
                                    <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="8">
                                        <Border BackgroundColor="{Binding ColorHex}" HeightRequest="38" WidthRequest="42">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding IconLabel}" TextColor="#05070D" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2" Text="Add" Command="{Binding AddCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border Margin="18,8,18,18" IsVisible="{Binding IsPageEditorSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Edit Page" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Button Grid.Column="1" Text="Done" Command="{Binding CloseSheetsCommand}" />
                    </Grid>
                    <Entry Grid.Row="1" Placeholder="Page name" Text="{Binding NewPageTitle, Mode=TwoWay}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Create Page" Command="{Binding AddPageCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Change Color" Command="{Binding CyclePageColorCommand}" />
                    </Grid>
                    <Label Grid.Row="3" Text="Rename existing pages remains a later store update." Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>

            <Border Margin="18,8,18,18" IsVisible="{Binding IsDeletePageConfirmationVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="{Binding DeletePagePrompt}" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Row="1" Text="This removes the page layout only. Library items stay available." Style="{StaticResource MutedLabelStyle}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Cancel" Command="{Binding CloseSheetsCommand}" />
                        <Button Grid.Column="1" Text="Delete Page" Command="{Binding ConfirmRemovePageCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
