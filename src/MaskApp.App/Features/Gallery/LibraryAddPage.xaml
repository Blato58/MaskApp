<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.LibraryAddPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:DataType="gallery:GalleryViewModel"
    Title="{loc:AppText Key=Ui016}"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{loc:AppText Key=Ui016}" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui141}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="{loc:AppText Key=Ui091}" Clicked="OnDoneClicked" />
            </Grid>

            <CollectionView ItemsSource="{Binding AddOptions}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="gallery:GalleryAddOption">
                        <Border Margin="0,0,0,12" Style="{StaticResource ActionCardBorderStyle}" Stroke="{Binding ColorHex}">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border BackgroundColor="{Binding ColorHex}" HeightRequest="44" Stroke="{Binding ColorHex}" WidthRequest="52">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding IconKey}" TextColor="#05070D" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding Subtitle}" Style="{StaticResource MutedLabelStyle}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <Button
                                    Grid.Row="2"
                                    Text="{loc:AppText Key=Ui072}"
                                    IsEnabled="{Binding IsAvailable}"
                                    Clicked="OnAddOptionClicked"
                                    CommandParameter="{Binding .}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
