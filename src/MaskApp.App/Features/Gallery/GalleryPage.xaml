<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.GalleryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:DataType="gallery:GalleryViewModel"
    Title="Library"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Margin="18,14,18,10" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Library" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{Binding VisibleItemCountText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Add" Clicked="OnAddClicked" Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
            <SearchBar
                x:Name="SearchBox"
                Grid.Row="1"
                Placeholder="Search Library"
                SearchButtonPressed="OnSearchDone"
                SemanticProperties.Description="Search saved mask content"
                Text="{Binding SearchText, Mode=TwoWay}" />
            <Grid Grid.Row="2" ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="8">
                <Button Text="Browse" Command="{Binding SetBrowseModeCommand}" Clicked="OnDismissSearchClicked" Style="{StaticResource PrimaryButtonStyle}" />
                <Button Grid.Column="1" Text="Edit" Command="{Binding SetArrangeModeCommand}" Clicked="OnDismissSearchClicked" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="2" Text="Filter" Command="{Binding ToggleFilterSheetCommand}" Clicked="OnDismissSearchClicked" Style="{StaticResource CompactButtonStyle}" />
                <Button Grid.Column="3" Text="Group" Command="{Binding ToggleGroupSheetCommand}" Clicked="OnDismissSearchClicked" Style="{StaticResource CompactButtonStyle}" />
            </Grid>
        </Grid>

        <CollectionView x:Name="LibraryView" Grid.Row="1" Margin="18,0" ItemsSource="{Binding Rows}" Scrolled="OnLibraryScrolled" SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="8">
                    <Label Text="Nothing here yet" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="Add a text preset, built-in favorite, or custom face." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryListRow">
                    <Grid>
                        <VerticalStackLayout IsVisible="{Binding IsGroupHeader}" Margin="0,18,0,6" Spacing="1">
                            <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />
                            <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>

                        <Border IsVisible="{Binding IsItemRow}" Style="{StaticResource ActionCardBorderStyle}">
                            <Grid>
                                <Grid IsVisible="{Binding Item.IsNormalMode}" ColumnDefinitions="72,*,Auto" ColumnSpacing="12" MinimumHeightRequest="92">
                                    <Grid>
                                        <controls:BuiltInPreviewView
                                            HeightRequest="82"
                                            WidthRequest="66"
                                            IsAnimationPlaying="{Binding Item.IsAnimationPlaying}"
                                            IsVisible="{Binding Item.HasPreview}"
                                            SemanticDescription="{Binding Item.Title, StringFormat='{0} preview'}"
                                            Source="{Binding Item.PreviewResourceName}" />
                                        <Border BackgroundColor="{Binding Item.ColorHex}" HeightRequest="52" WidthRequest="58" IsVisible="{Binding Item.HasPreview, Converter={StaticResource InvertedBoolConverter}}">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                            <Label Text="{Binding Item.IconKey}" TextColor="#050505" FontSize="10" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Title}" FontSize="17" FontAttributes="Bold" MaxLines="2" />
                                        <Label Text="{Binding Item.Subtitle}" Style="{StaticResource MutedLabelStyle}" MaxLines="2" />
                                        <Label Text="{Binding Item.TypeLabel}" Style="{StaticResource TinyLabelStyle}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                        <Label Text="{Binding Item.FavoriteLabel}" TextColor="{StaticResource AccentYellowColor}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                        <Button Text="Send" Clicked="OnSendClicked" CommandParameter="{Binding Item.Item}" Style="{StaticResource PrimaryButtonStyle}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid IsVisible="{Binding Item.IsEditMode}" ColumnDefinitions="*,Auto" ColumnSpacing="12" MinimumHeightRequest="96">
                                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Title}" FontSize="17" FontAttributes="Bold" />
                                        <Label Text="{Binding Item.DeleteEligibilityText}" Style="{StaticResource TinyLabelStyle}" />
                                        <Button Text="{Binding Item.SelectionText}" Command="{Binding Item.ToggleSelectionCommand}" HorizontalOptions="Start" Style="{StaticResource CompactButtonStyle}" />
                                    </VerticalStackLayout>
                                    <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                                        <Button Text="Up" Command="{Binding Item.MoveEarlierCommand}" Style="{StaticResource CompactButtonStyle}" />
                                        <Button Grid.Column="1" Text="Down" Command="{Binding Item.MoveLaterCommand}" Style="{StaticResource CompactButtonStyle}" />
                                        <Button Grid.Row="1" Grid.ColumnSpan="2" Text="Edit" Clicked="OnEditClicked" CommandParameter="{Binding Item.Item}" Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2">
            <Border Margin="18,8,18,18" IsVisible="{Binding IsFilterSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="Filter Library" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Grid.Row="1" Text="{Binding FilterSummaryText}" Style="{StaticResource MutedLabelStyle}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="All items" Command="{Binding ShowAllItemsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Favorites" Command="{Binding ShowFavoritesCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
            <Border Margin="18,8,18,18" IsVisible="{Binding IsGroupSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="Group items" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Picker Grid.Row="1" ItemsSource="{Binding GroupingOptions}" ItemDisplayBinding="{Binding Label}" SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" />
                </Grid>
            </Border>
            <Border Margin="18,8,18,18" IsVisible="{Binding HasSelection}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="{Binding SelectedCountText}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView Grid.Row="1" ItemsSource="{Binding SelectionActions}" SelectionMode="None" HeightRequest="118">
                        <CollectionView.ItemsLayout><GridItemsLayout Orientation="Vertical" Span="2" /></CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:GallerySelectionAction">
                                <Button Margin="0,0,8,8" Text="{Binding Title}" Command="{Binding Command}" Style="{StaticResource SecondaryButtonStyle}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
