<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.GalleryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="gallery:GalleryViewModel"
    Title="{x:Static loc:AppText.Library}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid>
        <CollectionView
            x:Name="LibraryView"
            ItemsSource="{Binding Rows}"
            Scrolled="OnLibraryScrolled"
            SelectionMode="None"
            IsVisible="{Binding IsContentVisible}">
            <CollectionView.Header>
                <VerticalStackLayout Padding="16,16,16,12" Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{x:Static loc:AppText.Library}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
                            <Label Text="{Binding VisibleItemCountText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="{x:Static loc:AppText.Add}"
                            Clicked="OnAddClicked"
                            Style="{StaticResource PrimaryButtonStyle}"
                            SemanticProperties.Description="{loc:AppText Key=Ui014}" />
                    </Grid>

                    <controls:ConnectionStatusView
                        State="{Binding ConnectionState}"
                        StateText="{Binding ConnectionStatusText}"
                        DetailText="{Binding ConnectionDetailText}" />

                    <SearchBar
                        x:Name="SearchBox"
                        Placeholder="{x:Static loc:AppText.SearchLibrary}"
                        SearchButtonPressed="OnSearchDone"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        SemanticProperties.Description="{loc:AppText Key=Ui298}" />

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="6">
                            <Button Text="{x:Static loc:AppText.All}" Command="{Binding ShowAllTypesCommand}" Style="{StaticResource FilterButtonStyle}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsAllFilterSelected}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Text="{x:Static loc:AppText.Faces}" Command="{Binding ShowFacesCommand}" Style="{StaticResource FilterButtonStyle}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsFacesFilterSelected}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Text="{x:Static loc:AppText.Text}" Command="{Binding ShowTextCommand}" Style="{StaticResource FilterButtonStyle}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsTextFilterSelected}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Text="{x:Static loc:AppText.Animations}" Command="{Binding ShowAnimationsCommand}" Style="{StaticResource FilterButtonStyle}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsAnimationsFilterSelected}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                            </Button>
                            <Button Text="{x:Static loc:AppText.Scenes}" Command="{Binding ShowScenesCommand}" Style="{StaticResource FilterButtonStyle}">
                                <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsScenesFilterSelected}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                            </Button>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <VerticalStackLayout IsVisible="{Binding HasQuickDeckItems}" Spacing="10">
                        <controls:SectionHeaderView Title="{x:Static loc:AppText.QuickDeck}" Subtitle="{loc:AppText Key=Ui113}" />
                        <CollectionView
                            ItemsSource="{Binding QuickDeckItems}"
                            HeightRequest="340"
                            SelectionMode="None">
                            <CollectionView.ItemsLayout><LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" /></CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="gallery:GalleryItemCard">
                                    <controls:LibraryItemCardView WidthRequest="174" Item="{Binding .}" EditRequested="OnCardEditRequested" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Text="{loc:AppText Key=Ui282}" Style="{StaticResource SectionTitleLabelStyle}" VerticalTextAlignment="Center" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui049}" Command="{Binding SetBrowseModeCommand}" Style="{StaticResource FilterButtonStyle}">
                            <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsBrowseMode}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                        </Button>
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui032}" Command="{Binding SetArrangeModeCommand}" Style="{StaticResource FilterButtonStyle}">
                            <Button.Triggers><DataTrigger TargetType="Button" Binding="{Binding IsArrangeMode}" Value="True"><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="TextColor" Value="{StaticResource AccentColor}" /></DataTrigger></Button.Triggers>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryListRow">
                    <Grid Margin="16,0,16,12">
                        <VerticalStackLayout IsVisible="{Binding IsGroupHeader}" Margin="0,12,0,2" Spacing="2">
                            <Label Text="{Binding Title}" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Grid IsVisible="{Binding IsItemRow}" ColumnDefinitions="*,*" ColumnSpacing="10">
                            <controls:LibraryItemCardView Item="{Binding Left}" EditRequested="OnCardEditRequested">
                                <controls:LibraryItemCardView.GestureRecognizers>
                                    <DragGestureRecognizer BindingContext="{Binding Left}" DragStarting="OnLibraryItemDragStarting" />
                                    <DropGestureRecognizer BindingContext="{Binding Left}" AllowDrop="True" Drop="OnLibraryItemDropped" />
                                </controls:LibraryItemCardView.GestureRecognizers>
                            </controls:LibraryItemCardView>
                            <controls:LibraryItemCardView Grid.Column="1" Item="{Binding Right}" IsVisible="{Binding HasRight}" EditRequested="OnCardEditRequested">
                                <controls:LibraryItemCardView.GestureRecognizers>
                                    <DragGestureRecognizer BindingContext="{Binding Right}" DragStarting="OnLibraryItemDragStarting" />
                                    <DropGestureRecognizer BindingContext="{Binding Right}" AllowDrop="True" Drop="OnLibraryItemDropped" />
                                </controls:LibraryItemCardView.GestureRecognizers>
                            </controls:LibraryItemCardView>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            HeightRequest="48"
            WidthRequest="48"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            SemanticProperties.Description="{loc:AppText Key=Ui159}" />

        <controls:EmptyStateView
            IsVisible="{Binding IsEmptyStateVisible}"
            Icon="◇"
            Title="{Binding EmptyStateTitle}"
            Message="{Binding EmptyStateMessage}"
            ActionText="{loc:AppText Key=Ui265}"
            ActionCommand="{Binding RetryCommand}"
            ShowAction="{Binding HasLoadError}"
            BackgroundColor="{StaticResource PageBackgroundColor}" />

        <Border
            Margin="16"
            Padding="12,8"
            BackgroundColor="{StaticResource PanelRaisedColor}"
            Stroke="{StaticResource PanelBorderColor}"
            HorizontalOptions="Center"
            VerticalOptions="End"
            IsVisible="{Binding IsSending}">
            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
            <HorizontalStackLayout Spacing="8">
                <ActivityIndicator IsRunning="{Binding IsSending}" HeightRequest="22" WidthRequest="22" />
                <Label Text="{Binding LastActionText, StringFormat='{loc:AppText Key=Ui429}'}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
