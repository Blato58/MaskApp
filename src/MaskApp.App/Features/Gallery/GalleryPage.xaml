<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.GalleryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:DataType="gallery:GalleryViewModel"
    Title="Gallery"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border Margin="18,16,18,8" Style="{StaticResource PanelBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Gallery" Style="{StaticResource PageTitleLabelStyle}" />
                        <Label Text="{Binding VisibleItemCountText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                    <ActivityIndicator
                        Grid.Column="1"
                        IsRunning="{Binding IsSending}"
                        IsVisible="{Binding IsSending}"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="2"
                        Text="Add"
                        Command="{Binding ToggleAddOptionsCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>

                <SearchBar
                    Grid.Row="1"
                    Placeholder="Search text, faces, anims, groups"
                    Text="{Binding SearchText, Mode=TwoWay}" />

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Picker
                        ItemsSource="{Binding GroupingOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" />
                    <HorizontalStackLayout Grid.Column="1" Spacing="8">
                        <Switch IsToggled="{Binding ShowFavoritesOnly, Mode=TwoWay}" />
                        <Label Text="Favorites" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                        <Switch IsToggled="{Binding IsEditMode, Mode=TwoWay}" />
                        <Label Text="{Binding GalleryModeText}" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Grid>

                <Label Grid.Row="3" Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
            </Grid>
        </Border>

        <CollectionView
            Grid.Row="1"
            Margin="18,0"
            ItemsSource="{Binding Groups}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryGroupCard">
                    <Border Margin="0,0,0,14" Style="{StaticResource PanelBorderStyle}">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Title}" Style="{StaticResource SectionTitleLabelStyle}" />
                                    <Label Text="{Binding Count, StringFormat='{}{0} items'}" Style="{StaticResource TinyLabelStyle}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Up" Command="{Binding MoveEarlierCommand}" IsVisible="{Binding IsEditMode}" />
                                <Button Grid.Column="2" Text="Down" Command="{Binding MoveLaterCommand}" IsVisible="{Binding IsEditMode}" />
                            </Grid>

                            <CollectionView
                                Grid.Row="1"
                                ItemsSource="{Binding Items}"
                                SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="2" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="gallery:GalleryItemCard">
                                        <Grid>
                                            <Border
                                                Margin="0,0,8,10"
                                                IsVisible="{Binding IsNormalMode}"
                                                MinimumHeightRequest="78"
                                                Style="{StaticResource ActionCardBorderStyle}"
                                                Stroke="{Binding ColorHex}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SendCommand}" />
                                                </Border.GestureRecognizers>
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Border
                                                        BackgroundColor="{Binding ColorHex}"
                                                        HeightRequest="34"
                                                        Stroke="{Binding ColorHex}"
                                                        WidthRequest="44">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8" />
                                                        </Border.StrokeShape>
                                                        <Label
                                                            Text="{Binding IconKey}"
                                                            TextColor="#05070D"
                                                            FontSize="9"
                                                            FontAttributes="Bold"
                                                            HorizontalTextAlignment="Center"
                                                            VerticalTextAlignment="Center" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                        <Label Text="{Binding TypeLabel}" Style="{StaticResource TinyLabelStyle}" />
                                                        <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>

                                            <Border
                                                Margin="0,0,8,10"
                                                IsVisible="{Binding IsEditMode}"
                                                MinimumHeightRequest="160"
                                                Style="{StaticResource ActionCardBorderStyle}"
                                                Stroke="{Binding ColorHex}">
                                                <Grid ColumnDefinitions="*,96" ColumnSpacing="10">
                                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                                        <Label Text="{Binding TypeLabel}" Style="{StaticResource TinyLabelStyle}" />
                                                        <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="7">
                                                        <Button Text="Move up" Command="{Binding MoveEarlierCommand}" />
                                                        <Button
                                                            Text="Manage"
                                                            Clicked="OnManageClicked"
                                                            CommandParameter="{Binding Item}"
                                                            IsVisible="{Binding CanManage}" />
                                                        <Button Text="Move down" Command="{Binding MoveLaterCommand}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border
            Grid.Row="2"
            Margin="18,8,18,16"
            IsVisible="{Binding IsAddOptionsVisible}"
            Style="{StaticResource PanelBorderStyle}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                <Label Text="Add or manage" Style="{StaticResource SectionTitleLabelStyle}" />
                <CollectionView
                    Grid.Row="1"
                    HeightRequest="170"
                    ItemsSource="{Binding AddOptions}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="gallery:GalleryAddOption">
                            <Button
                                Margin="0,0,8,8"
                                BorderColor="{Binding ColorHex}"
                                Clicked="OnAddOptionClicked"
                                CommandParameter="{Binding .}"
                                Text="{Binding Title}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
