<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.GalleryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:DataType="gallery:GalleryViewModel"
    Title="Library"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border Margin="18,18,18,10" Style="{StaticResource PanelBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Library" Style="{StaticResource PageTitleLabelStyle}" />
                        <Label Text="{Binding VisibleItemCountText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="+ Add" Clicked="OnAddClicked" Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <SearchBar
                        x:Name="SearchBox"
                        Placeholder="Search items"
                        SearchButtonPressed="OnSearchDone"
                        Text="{Binding SearchText, Mode=TwoWay}" />
                    <Button Grid.Column="1" Text="Done" Clicked="OnSearchDone" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Browse" Command="{Binding SetBrowseModeCommand}" Clicked="OnDismissSearchClicked" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1" Text="Arrange" Command="{Binding SetArrangeModeCommand}" Clicked="OnDismissSearchClicked" />
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Button Text="{Binding FilterSummaryText, StringFormat='Filter: {0}'}" Command="{Binding ToggleFilterSheetCommand}" Clicked="OnDismissSearchClicked" />
                    <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                        <Label Text="{Binding GalleryModeText}" Style="{StaticResource ChipLabelStyle}" />
                    </Border>
                </Grid>

                <Button
                    Grid.Row="4"
                    Text="{Binding GroupSummaryText, StringFormat='Group: {0}'}"
                    Command="{Binding ToggleGroupSheetCommand}"
                    Clicked="OnDismissSearchClicked" />
            </Grid>
        </Border>

        <CollectionView
            Grid.Row="1"
            Margin="18,0"
            ItemsSource="{Binding Rows}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryListRow">
                    <Grid>
                        <Grid IsVisible="{Binding IsGroupHeader}" ColumnDefinitions="*,Auto" Margin="0,10,0,8">
                            <VerticalStackLayout Spacing="1">
                                <Label Text="{Binding Title}" FontSize="22" FontAttributes="Bold" />
                                <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid IsVisible="{Binding IsItemRow}" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,0,0,12">
                            <Grid>
                                <Border
                                    HeightRequest="184"
                                    IsVisible="{Binding Left.IsNormalMode}"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Left.ColorHex}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBrowseCardTapped" CommandParameter="{Binding Left.Item}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border BackgroundColor="{Binding Left.ColorHex}" HeightRequest="38" Stroke="{Binding Left.ColorHex}" WidthRequest="44">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Left.IconKey}" TextColor="#05070D" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Grid.Column="1" Text="{Binding Left.TypeLabel}" Style="{StaticResource TinyLabelStyle}" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="2" Text="{Binding Left.FavoriteLabel}" TextColor="{StaticResource AccentYellowColor}" FontAttributes="Bold" />
                                        </Grid>
                                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                                            <Label Text="{Binding Left.Title}" FontSize="18" FontAttributes="Bold" MaxLines="2" />
                                            <Label Text="{Binding Left.Subtitle}" Style="{StaticResource MutedLabelStyle}" MaxLines="2" />
                                        </VerticalStackLayout>
                                        <Label Grid.Row="2" Text="{Binding Left.LastSendStatus}" Style="{StaticResource TinyLabelStyle}" />
                                    </Grid>
                                </Border>

                                <Border
                                    HeightRequest="220"
                                    IsVisible="{Binding Left.IsEditMode}"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Left.ColorHex}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Button Text="{Binding Left.SelectionText}" Command="{Binding Left.ToggleSelectionCommand}" Padding="8,4" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                <Label Text="{Binding Left.Title}" FontSize="17" FontAttributes="Bold" MaxLines="2" />
                                                <Label Text="{Binding Left.DeleteEligibilityText}" Style="{StaticResource TinyLabelStyle}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Button Grid.Row="1" Text="Move up" Command="{Binding Left.MoveEarlierCommand}" />
                                        <Button Grid.Row="2" Text="Edit" Clicked="OnEditClicked" CommandParameter="{Binding Left.Item}" />
                                        <Button Grid.Row="3" Text="Move down" Command="{Binding Left.MoveLaterCommand}" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="1" IsVisible="{Binding HasRight}">
                                <Border
                                    HeightRequest="184"
                                    IsVisible="{Binding Right.IsNormalMode}"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Right.ColorHex}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBrowseCardTapped" CommandParameter="{Binding Right.Item}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border BackgroundColor="{Binding Right.ColorHex}" HeightRequest="38" Stroke="{Binding Right.ColorHex}" WidthRequest="44">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Right.IconKey}" TextColor="#05070D" FontSize="9" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            </Border>
                                            <Label Grid.Column="1" Text="{Binding Right.TypeLabel}" Style="{StaticResource TinyLabelStyle}" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="2" Text="{Binding Right.FavoriteLabel}" TextColor="{StaticResource AccentYellowColor}" FontAttributes="Bold" />
                                        </Grid>
                                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                                            <Label Text="{Binding Right.Title}" FontSize="18" FontAttributes="Bold" MaxLines="2" />
                                            <Label Text="{Binding Right.Subtitle}" Style="{StaticResource MutedLabelStyle}" MaxLines="2" />
                                        </VerticalStackLayout>
                                        <Label Grid.Row="2" Text="{Binding Right.LastSendStatus}" Style="{StaticResource TinyLabelStyle}" />
                                    </Grid>
                                </Border>

                                <Border
                                    HeightRequest="220"
                                    IsVisible="{Binding Right.IsEditMode}"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Right.ColorHex}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Button Text="{Binding Right.SelectionText}" Command="{Binding Right.ToggleSelectionCommand}" Padding="8,4" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                <Label Text="{Binding Right.Title}" FontSize="17" FontAttributes="Bold" MaxLines="2" />
                                                <Label Text="{Binding Right.DeleteEligibilityText}" Style="{StaticResource TinyLabelStyle}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Button Grid.Row="1" Text="Move up" Command="{Binding Right.MoveEarlierCommand}" />
                                        <Button Grid.Row="2" Text="Edit" Clicked="OnEditClicked" CommandParameter="{Binding Right.Item}" />
                                        <Button Grid.Row="3" Text="Move down" Command="{Binding Right.MoveLaterCommand}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2">
            <Border Margin="18,8,18,18" IsVisible="{Binding IsFilterSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="Filter Library" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Grid.Row="1" Text="{Binding FilterSummaryText}" Style="{StaticResource MutedLabelStyle}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="All items" Command="{Binding ShowAllItemsCommand}" />
                        <Button Grid.Column="1" Text="Favorites" Command="{Binding ShowFavoritesCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Margin="18,8,18,18" IsVisible="{Binding IsGroupSheetVisible}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="Group Items" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Picker Grid.Row="1" ItemsSource="{Binding GroupingOptions}" ItemDisplayBinding="{Binding Label}" SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Margin="18,8,18,18" IsVisible="{Binding HasSelection}" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="{Binding SelectedCountText}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView Grid.Row="1" ItemsSource="{Binding SelectionActions}" SelectionMode="None" HeightRequest="118">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:GallerySelectionAction">
                                <Button Margin="0,0,8,8" Text="{Binding Title}" Command="{Binding Command}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
