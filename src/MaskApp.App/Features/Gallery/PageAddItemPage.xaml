<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Gallery.PageAddItemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    x:DataType="gallery:PageAddItemViewModel"
    Title="Add Shortcut"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="14">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Add Shortcut" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{Binding PageTitle}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Cancel" Clicked="OnCancelClicked" />
                <Button Grid.Column="2" Text="Save" IsEnabled="{Binding CanSave}" Clicked="OnSaveClicked" Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>

            <Border Style="{StaticResource PanelBorderStyle}" Stroke="{Binding SelectedColorHex}">
                <Grid ColumnDefinitions="96,*" ColumnSpacing="14">
                    <Border BackgroundColor="{Binding SelectedColorHex}" HeightRequest="96" WidthRequest="96" IsVisible="{Binding SelectedItemHasAnyPreview, Converter={StaticResource InvertedBoolConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Grid RowDefinitions="*,Auto" Padding="8">
                            <Image Source="{Binding PreviewIconAsset}" Aspect="AspectFit" HeightRequest="42" WidthRequest="42" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Label Grid.Row="1" Text="{Binding PreviewLabel}" TextColor="#05070D" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />
                        </Grid>
                    </Border>
                    <controls:BuiltInPreviewView
                        HeightRequest="96"
                        WidthRequest="96"
                        IsAnimationPlaying="False"
                        IsVisible="{Binding SelectedItemHasPreview}"
                        SemanticDescription="{Binding SelectedItemTitle, StringFormat='{0} preview'}"
                        Source="{Binding SelectedPreviewResourceName}" />
                    <controls:FacePatternPreviewView
                        HeightRequest="96"
                        WidthRequest="96"
                        IsVisible="{Binding SelectedItemHasFacePreview}"
                        Pattern="{Binding SelectedFacePattern}"
                        SemanticDescription="{Binding SelectedItemTitle, StringFormat='{0} face preview'}" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="{Binding SelectedItemTitle}" FontSize="20" FontAttributes="Bold" />
                        <Label Text="{Binding SelectedItemSubtitle}" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding SaveSummaryText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="Gallery Item" Style="{StaticResource SectionTitleLabelStyle}" />
                    <SearchBar Grid.Row="1" Placeholder="Search Library items" Text="{Binding SearchText, Mode=TwoWay}" />
                    <CollectionView x:Name="AvailableItemsView" Grid.Row="2" HeightRequest="280" ItemsSource="{Binding AvailableItems}" Scrolled="OnAvailableItemsScrolled" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="No available Gallery items for this page." Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:PageAddItemCandidateCard">
                                <Border Margin="0,0,8,8" Style="{StaticResource ActionCardBorderStyle}" Stroke="{Binding ColorHex}">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="42,*" ColumnSpacing="8">
                                            <Border BackgroundColor="{Binding ColorHex}" HeightRequest="38" WidthRequest="42">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Image Source="{Binding IconAsset}" Aspect="AspectFit" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Subtitle}" Style="{StaticResource TinyLabelStyle}" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <controls:BuiltInPreviewView
                                            Grid.Row="1"
                                            HeightRequest="104"
                                            IsAnimationPlaying="{Binding IsAnimationPlaying}"
                                            IsVisible="{Binding HasPreview}"
                                            SemanticDescription="{Binding Title, StringFormat='{0} preview'}"
                                            Source="{Binding PreviewResourceName}" />
                                        <controls:FacePatternPreviewView
                                            Grid.Row="1"
                                            HeightRequest="104"
                                            IsVisible="{Binding HasFacePreview}"
                                            Pattern="{Binding FacePattern}"
                                            SemanticDescription="{Binding Title, StringFormat='{0} face preview'}" />
                                        <Button Grid.Row="2" Text="{Binding SelectionText}" Command="{Binding SelectCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="Text" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Entry Grid.Row="1" Placeholder="Shortcut label" Text="{Binding DraftLabel, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="Color" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView Grid.Row="1" HeightRequest="64" ItemsSource="{Binding Colors}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:PageAddItemColorCard">
                                <Button
                                    BackgroundColor="{Binding ColorHex}"
                                    BorderColor="{Binding ColorHex}"
                                    Command="{Binding SelectCommand}"
                                    HeightRequest="48"
                                    Text="{Binding SelectionText}"
                                    TextColor="#05070D"
                                    WidthRequest="92" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="Icon" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView Grid.Row="1" HeightRequest="56" ItemsSource="{Binding IconPacks}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:PageAddItemPackCard">
                                <Button Text="{Binding Label}" Command="{Binding SelectCommand}" Style="{StaticResource NeonBlueButtonStyle}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView Grid.Row="2" HeightRequest="284" ItemsSource="{Binding Icons}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="gallery:PageAddItemIconCard">
                                <Border Margin="0,0,8,10" Style="{StaticResource ActionCardBorderStyle}" Stroke="{Binding ColorHex}">
                                    <Grid RowDefinitions="*,Auto,Auto" RowSpacing="4">
                                        <Border BackgroundColor="{Binding ColorHex}" HeightRequest="56" WidthRequest="64" HorizontalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Image Source="{Binding PreviewAsset}" Aspect="AspectFit" HeightRequest="34" WidthRequest="34" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <Label Grid.Row="1" Text="{Binding Label}" Style="{StaticResource TinyLabelStyle}" HorizontalTextAlignment="Center" />
                                        <Button Grid.Row="2" Text="{Binding SelectionText}" Command="{Binding SelectCommand}" Padding="6,4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Label Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
