<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Home.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:home="clr-namespace:MaskApp.Core.Features.Home;assembly=MaskApp.Core"
    x:DataType="home:HomeViewModel"
    Title="Control"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="18">
            <VerticalStackLayout Spacing="6">
                <Label Text="{Binding AppTitle}" Style="{StaticResource PageTitleLabelStyle}" />
                <Label Text="{Binding Summary}" Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Mask status" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Border
                            Grid.Column="1"
                            Padding="8,3"
                            BackgroundColor="{StaticResource ChipBackgroundColor}"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="{Binding CommandTransportState}" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="4">
                        <Label Text="Control" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding ControlTransportText}" />

                        <Label Grid.Row="1" Text="Status" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding CommandTransportStatusText}" />

                        <Label Grid.Row="2" Text="Text" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TextTransportText}" />

                        <Label Grid.Row="3" Text="Upload" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TextTransportStatusText}" />
                    </Grid>

                    <Label Grid.Row="2" Text="{Binding RecoveryHint}" Style="{StaticResource MutedLabelStyle}" />

                    <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Open Connect" Clicked="OnOpenConnectClicked" />
                        <Button Grid.Column="1" Text="Open Text" Clicked="OnOpenTextClicked" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Live controls" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding BrightnessText}" Style="{StaticResource MutedLabelStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="BLACKOUT" Command="{Binding BlackoutCommand}" />
                        <Button Grid.Column="1" Text="Restore" Command="{Binding RestoreBrightnessCommand}" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Slider
                            Minimum="1"
                            Maximum="100"
                            Value="{Binding Brightness, Mode=TwoWay}" />
                        <Button Grid.Column="1" Text="Apply" Command="{Binding ApplyBrightnessCommand}" />
                    </Grid>

                    <VerticalStackLayout Grid.Row="3" Spacing="4">
                        <Label Text="{Binding CurrentLookText}" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding LastActionStatus}" Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Fast reactions" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Button Grid.Column="1" Text="Random" Command="{Binding RandomReactionCommand}" />
                    </Grid>
                    <Label
                        Grid.Row="1"
                        Text="{Binding TextAcknowledgementText}"
                        Style="{StaticResource MutedLabelStyle}" />

                    <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                        <Label Text="Favorites" FontAttributes="Bold" />
                        <FlexLayout
                            Grid.Row="1"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding FavoriteReactions}"
                            Direction="Row"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="home:HomeQuickActionCard">
                                    <Button
                                        Margin="0,0,8,8"
                                        Text="{Binding Label}"
                                        Command="{Binding TriggerCommand}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Label Grid.Row="2" Text="Recent" FontAttributes="Bold" />
                        <FlexLayout
                            Grid.Row="3"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding RecentReactions}"
                            Direction="Row"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="home:HomeQuickActionCard">
                                    <Button
                                        Margin="0,0,8,8"
                                        Text="{Binding Label}"
                                        Command="{Binding TriggerCommand}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </Grid>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
