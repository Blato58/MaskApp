<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Home.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:home="clr-namespace:MaskApp.Core.Features.Home;assembly=MaskApp.Core"
    xmlns:presets="clr-namespace:MaskApp.Core.Features.TextPresets;assembly=MaskApp.Core"
    xmlns:quick="clr-namespace:MaskApp.Core.Features.QuickActions;assembly=MaskApp.Core"
    x:DataType="home:HomeViewModel"
    Title="Control"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid ColumnDefinitions="86,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto">
                    <Image
                        Grid.RowSpan="3"
                        Aspect="AspectFit"
                        HeightRequest="82"
                        Source="mask_neon.svg"
                        WidthRequest="82" />
                    <Label Grid.Column="1" Text="MaskApp" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="Control. Express. Rave."
                        Style="{StaticResource MutedLabelStyle}" />
                    <Label
                        Grid.Row="2"
                        Grid.Column="1"
                        Text="{Binding Summary}"
                        Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Mask status" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding RecoveryHint}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Border
                            Grid.Column="1"
                            Style="{StaticResource StatusPillBorderStyle}"
                            Stroke="{Binding CommandTransportState, Converter={StaticResource TransportStateColorConverter}}">
                            <Label
                                Text="{Binding CommandTransportState}"
                                TextColor="{Binding CommandTransportState, Converter={StaticResource TransportStateColorConverter}}"
                                Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="10">
                        <Border
                            BackgroundColor="{Binding CommandTransportState, Converter={StaticResource TransportStateColorConverter}, ConverterParameter=soft}"
                            Stroke="{Binding CommandTransportState, Converter={StaticResource TransportStateColorConverter}}"
                            Style="{StaticResource CompactPanelBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Control" Style="{StaticResource TinyLabelStyle}" />
                                <Label Text="{Binding ControlTransportText}" FontAttributes="Bold" />
                                <Label Text="{Binding CommandTransportStatusText}" Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border
                            Grid.Column="1"
                            BackgroundColor="{Binding TextTransportState, Converter={StaticResource TransportStateColorConverter}, ConverterParameter=soft}"
                            Stroke="{Binding TextTransportState, Converter={StaticResource TransportStateColorConverter}}"
                            Style="{StaticResource CompactPanelBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Text" Style="{StaticResource TinyLabelStyle}" />
                                <Label Text="{Binding TextTransportText}" FontAttributes="Bold" />
                                <Label Text="{Binding TextTransportStatusText}" Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Connect" Clicked="OnOpenConnectClicked" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Text Composer" Clicked="OnOpenTextClicked" Style="{StaticResource NeonBlueButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Bluetooth" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding AutoConnectStatusText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="Connect now"
                            Command="{Binding StartAutoConnectCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource CompactPanelBorderStyle}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Text="Last mask" Style="{StaticResource TinyLabelStyle}" />
                            <Label Grid.Column="1" Text="{Binding LastKnownMaskText}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="Foreground only" Style="{StaticResource TinyLabelStyle}" />
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="Forget"
                                Command="{Binding ForgetKnownMaskCommand}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Switch IsToggled="{Binding AutoConnectEnabled, Mode=TwoWay}" />
                            <Label Text="Auto-connect on launch" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Switch IsToggled="{Binding RememberLastDeviceEnabled, Mode=TwoWay}" />
                            <Label Text="Remember mask" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="Quick controls" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding BrightnessText}" Style="{StaticResource MetricLabelStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            HeightRequest="58"
                            Text="BLACKOUT"
                            Command="{Binding BlackoutCommand}"
                            Style="{StaticResource DangerButtonStyle}" />
                        <Button
                            Grid.Column="1"
                            HeightRequest="58"
                            Text="Restore"
                            Command="{Binding RestoreBrightnessCommand}"
                            Style="{StaticResource BrightButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Slider
                            Minimum="1"
                            Maximum="100"
                            Value="{Binding Brightness, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            Text="Apply"
                            Command="{Binding ApplyBrightnessCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>

                    <VerticalStackLayout Grid.Row="3" Spacing="4">
                        <Label Text="{Binding CurrentLookText}" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding LastActionStatus}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Reaction strip" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding TextAcknowledgementText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="Surprise"
                            Command="{Binding RandomReactionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>

                    <Label Grid.Row="1" Text="Favorites" FontAttributes="Bold" />
                    <FlexLayout
                        Grid.Row="2"
                        AlignItems="Stretch"
                        BindableLayout.ItemsSource="{Binding FavoriteReactions}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="home:HomeQuickActionCard">
                                <Border
                                    Margin="0,0,10,10"
                                    MinimumWidthRequest="132"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Border
                                                BackgroundColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}"
                                                HeightRequest="34"
                                                Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                StrokeThickness="1"
                                                WidthRequest="44">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Label
                                                    HorizontalTextAlignment="Center"
                                                    Text="{Binding Id, Converter={StaticResource QuickActionIconConverter}}"
                                                    TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                    VerticalTextAlignment="Center"
                                                    FontSize="11"
                                                    FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="1" Text="{Binding Label}" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                        </Grid>
                                        <Label Grid.Row="1" Text="{Binding Description}" Style="{StaticResource TinyLabelStyle}" />
                                        <Button
                                            Grid.Row="2"
                                            Text="Send"
                                            Command="{Binding TriggerCommand}"
                                            BorderColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                            TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                            BackgroundColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Label Grid.Row="3" Text="Recent" FontAttributes="Bold" />
                    <FlexLayout
                        Grid.Row="4"
                        AlignItems="Stretch"
                        BindableLayout.ItemsSource="{Binding RecentReactions}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="home:HomeQuickActionCard">
                                <Button
                                    Margin="0,0,8,8"
                                    MinimumWidthRequest="118"
                                    Text="{Binding Label}"
                                    Command="{Binding TriggerCommand}"
                                    BorderColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                    TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                    BackgroundColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Favorite text presets" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="Saved per-caption style from Text Composer." Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                            <Label Text="{Binding FavoriteTextPresets.Count, StringFormat='{}{0} presets'}" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>
                    <FlexLayout
                        Grid.Row="1"
                        AlignItems="Stretch"
                        BindableLayout.ItemsSource="{Binding FavoriteTextPresets}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="presets:TextPresetCard">
                                <Border
                                    Margin="0,0,10,10"
                                    MinimumWidthRequest="142"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding ColorHex}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SendCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <BoxView Color="{Binding ColorHex}" HeightRequest="18" WidthRequest="18" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding DisplayName}" FontAttributes="Bold" />
                                        </Grid>
                                        <Label Grid.Row="1" Text="{Binding InputText}" TextColor="{Binding ColorHex}" FontAttributes="Bold" />
                                        <Button Grid.Row="2" Text="Send" Command="{Binding SendCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Quick caption settings" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="Used by Control, React, and RAVE quick text." Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="Reset"
                            Command="{Binding ResetQuickCaptionSettingsCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Mode" Style="{StaticResource TinyLabelStyle}" />
                            <Picker
                                ItemDisplayBinding="{Binding Label}"
                                ItemsSource="{Binding QuickCaptionModeOptions}"
                                SelectedItem="{Binding SelectedQuickCaptionMode, Mode=TwoWay}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Send mode" Style="{StaticResource TinyLabelStyle}" />
                            <Picker
                                ItemDisplayBinding="{Binding Label}"
                                ItemsSource="{Binding QuickCaptionSendModeOptions}"
                                SelectedItem="{Binding SelectedQuickCaptionSendMode, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding QuickCaptionSpeedText, StringFormat='Speed {0}'}" Style="{StaticResource TinyLabelStyle}" />
                            <Slider
                                Minimum="1"
                                Maximum="100"
                                Value="{Binding QuickCaptionSpeed, Mode=TwoWay}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                            <Label Text="Default 100" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="3" RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="{Binding QuickCaptionForegroundText}" Style="{StaticResource TinyLabelStyle}" />
                        <FlexLayout
                            Grid.Row="1"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding QuickCaptionForegroundPresetOptions}"
                            Direction="Row"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="quick:QuickCaptionForegroundPresetOption">
                                    <Button
                                        Margin="0,0,8,8"
                                        Padding="12,8"
                                        BackgroundColor="{Binding Hex}"
                                        BorderColor="{Binding Hex}"
                                        Clicked="OnForegroundColorClicked"
                                        CommandParameter="{Binding .}"
                                        Text="{Binding Label}"
                                        TextColor="#05070D" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </Grid>

                    <Label
                        Grid.Row="4"
                        Text="{Binding QuickCaptionBackgroundNote}"
                        Style="{StaticResource TinyLabelStyle}" />
                    <Label
                        Grid.Row="5"
                        Text="Default: Centered 44-column, Blink, speed 50, Low-static Flash, white text, backgrounds disabled."
                        TextColor="{StaticResource AccentYellowColor}"
                        Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
