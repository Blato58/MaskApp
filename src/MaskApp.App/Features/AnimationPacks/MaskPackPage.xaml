<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.AnimationPacks.MaskPackPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:packs="clr-namespace:MaskApp.Core.Features.AnimationPacks;assembly=MaskApp.Core"
    x:DataType="packs:MaskPackViewModel"
    Title="{loc:Translate MaskPack}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <ScrollView x:Name="TransferScroll">
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{loc:Translate MaskPack}" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{loc:Translate MaskPackSubtitle}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </Grid>

            <Border x:Name="ImportSection" Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static loc:AppText.Import}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:Translate ImportValidationDetail}" Style="{StaticResource MutedLabelStyle}" />
                    <Button Text="{loc:Translate ChooseMaskPack}" Clicked="OnChoosePackClicked" Style="{StaticResource PrimaryButtonStyle}" />
                    <Label Text="{Binding InspectionSummary}" FontAttributes="Bold" />
                    <Label Text="{Binding DetailsText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" IsVisible="{Binding HasConflicts}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:Translate ConflictPreview}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:Translate ConflictPreviewDetail}" Style="{StaticResource MutedLabelStyle}" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Conflicts}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="packs:MaskPackConflictChoice">
                                <Border Padding="12" Stroke="#64748B" BackgroundColor="#111827">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource TinyLabelStyle}" />
                                        <Picker
                                            Grid.Row="2"
                                            Title="{loc:Translate ConflictAction}"
                                            ItemsSource="{Binding ResolutionOptions}"
                                            SelectedItem="{Binding Resolution, Mode=TwoWay}"
                                            SemanticProperties.Description="{loc:Translate ConflictActionDescription}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsVisible="{Binding RequiresReplaceConfirmation}">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{loc:Translate ConfirmReplacement}" FontAttributes="Bold" />
                            <Label Text="{loc:Translate ConfirmReplacementDetail}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding ConfirmReplace, Mode=TwoWay}" SemanticProperties.Description="{loc:Translate ConfirmReplacementDescription}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                Text="{loc:Translate ImportInspectedPackage}"
                Command="{Binding ImportCommand}"
                IsVisible="{Binding HasValidInspection}"
                Style="{StaticResource PrimaryButtonStyle}" />

            <Border x:Name="ExportSection" Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static loc:AppText.Export}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:Translate ExportMaskPackDetail}" Style="{StaticResource MutedLabelStyle}" />
                    <Entry Placeholder="{loc:Translate PackName}" Text="{Binding PackName, Mode=TwoWay}" />
                    <Entry Placeholder="{loc:Translate Author}" Text="{Binding Author, Mode=TwoWay}" />
                    <Button Text="{loc:Translate ExportShareMaskPack}" Clicked="OnExportPackClicked" Style="{StaticResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource StatusBorderStyle}">
                <Label Text="{Binding StatusText}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
