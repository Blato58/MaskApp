<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.AnimationPacks.MaskPackPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:packs="clr-namespace:MaskApp.Core.Features.AnimationPacks;assembly=MaskApp.Core"
    x:DataType="packs:MaskPackViewModel"
    Title="{loc:AppText Key=Ui170}"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{loc:AppText Key=Ui170}" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui176}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </Grid>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui144}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui339}" Style="{StaticResource MutedLabelStyle}" />
                    <Button Text="{loc:AppText Key=Ui139}" Clicked="OnChoosePackClicked" Style="{StaticResource PrimaryButtonStyle}" />
                    <Label Text="{Binding InspectionSummary}" FontAttributes="Bold" />
                    <Label Text="{Binding DetailsText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" IsVisible="{Binding HasConflicts}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:AppText Key=Ui068}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui135}" Style="{StaticResource MutedLabelStyle}" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Conflicts}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="packs:MaskPackConflictChoice">
                                <Border Padding="12" Stroke="#64748B" BackgroundColor="#111827">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Text="{Binding Detail}" Style="{StaticResource TinyLabelStyle}" />
                                        <Picker
                                            Grid.Row="2"
                                            Title="{loc:AppText Key=Ui066}"
                                            ItemsSource="{Binding ResolutionOptions}"
                                            SelectedItem="{Binding Resolution, Mode=TwoWay}"
                                            SemanticProperties.Description="{loc:AppText Key=Ui067}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsVisible="{Binding RequiresReplaceConfirmation}">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{loc:AppText Key=Ui064}" FontAttributes="Bold" />
                            <Label Text="{loc:AppText Key=Ui262}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding ConfirmReplace, Mode=TwoWay}" SemanticProperties.Description="{loc:AppText Key=Ui065}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                Text="{loc:AppText Key=Ui145}"
                Command="{Binding ImportCommand}"
                IsVisible="{Binding HasValidInspection}"
                Style="{StaticResource PrimaryButtonStyle}" />

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui104}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui107}" Style="{StaticResource MutedLabelStyle}" />
                    <Entry Placeholder="{loc:AppText Key=Ui212}" Text="{Binding PackName, Mode=TwoWay}" />
                    <Entry Placeholder="{loc:AppText Key=Ui036}" Text="{Binding Author, Mode=TwoWay}" />
                    <Button Text="{loc:AppText Key=Ui105}" Clicked="OnExportPackClicked" Style="{StaticResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource StatusBorderStyle}">
                <Label Text="{Binding StatusText}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
