<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.BuiltIns.StockContentDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:builtins="clr-namespace:MaskApp.Core.Features.BuiltIns;assembly=MaskApp.Core"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="builtins:BuiltInsViewModel"
    Title="{loc:Translate StockContent}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding DisplayName}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
                        <Label Text="{Binding CurrentPreviewBadgeText}" Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="{Binding FavoriteButtonText}" Command="{Binding ToggleFavoriteCommand}" MinimumHeightRequest="48" />
                </Grid>
                <controls:BuiltInPreviewView
                    x:Name="DetailPreview"
                    HeightRequest="280"
                    Source="{Binding CurrentPreviewResourceName}"
                    SemanticDescription="{Binding DisplayName, StringFormat='{0} exact stock preview'}" />
                <controls:InlineIssue
                    Title="{loc:Translate PhysicalOutput}"
                    Detail="{loc:Translate PhysicalOutputDetail}" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Text="{x:Static loc:AppText.Previous}" Command="{Binding PreviousCommand}" />
                    <Button Grid.Column="1" Text="{loc:Translate SendTest}" Command="{Binding SendCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="2" Text="{x:Static loc:AppText.Next}" Command="{Binding NextCommand}" />
                </Grid>
                <Border Style="{StaticResource PanelBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Translate TestMetadata}" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Text="{Binding CurrentHexId, StringFormat='Protocol ID {0}'}" />
                        <Label Text="{Binding CurrentPreviewSourceText}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Text="{Binding LastTestedText}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Text="{Binding LastSendStatus}" Style="{StaticResource MutedLabelStyle}" />
                        <Entry Placeholder="{loc:Translate DisplayName}" Text="{Binding DisplayName, Mode=TwoWay}" />
                        <Entry Placeholder="{loc:Translate TagsCommaSeparated}" Text="{Binding TagsText, Mode=TwoWay}" />
                        <Editor Placeholder="{loc:Translate Notes}" Text="{Binding Notes, Mode=TwoWay}" AutoSize="TextChanges" HeightRequest="96" />
                        <Picker Title="{loc:Translate ObservedStatus}" ItemsSource="{Binding StatusValues}" SelectedItem="{Binding AssetStatus, Mode=TwoWay}" />
                        <Button Text="{loc:Translate SaveMetadata}" Command="{Binding SaveCommand}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Grid Grid.Row="1" Padding="16,10" BackgroundColor="{AppThemeBinding Dark={StaticResource DarkSurfaceColor}, Light={StaticResource LightSurfaceColor}}" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label Text="{Binding TransportReadinessText}" Style="{StaticResource MutedLabelStyle}" VerticalTextAlignment="Center" />
            <Button Grid.Column="1" Text="{x:Static loc:AppText.Blackout}" Command="{Binding BlackoutCommand}" Style="{StaticResource DangerButtonStyle}" MinimumHeightRequest="56" />
        </Grid>
    </Grid>
</ContentPage>
