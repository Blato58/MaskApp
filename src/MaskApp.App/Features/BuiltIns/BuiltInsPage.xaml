<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.BuiltIns.BuiltInsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:builtins="clr-namespace:MaskApp.Core.Features.BuiltIns;assembly=MaskApp.Core"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="builtins:BuiltInsViewModel"
    Title="{loc:AppText Key=Ui053}"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,Auto,*" Padding="18,14,18,0" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="{loc:AppText Key=Ui053}" Style="{StaticResource PageTitleLabelStyle}" />
                <Label Text="{Binding CatalogSummaryText}" Style="{StaticResource TinyLabelStyle}" />
            </VerticalStackLayout>
            <Button
                Grid.Column="1"
                Text="{loc:AppText Key=Ui045}"
                Command="{Binding BlackoutCommand}"
                SemanticProperties.Hint="{loc:AppText Key=Ui143}"
                Style="{StaticResource DangerButtonStyle}" />
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button
                    Text="{loc:AppText Key=Ui110}"
                    Command="{Binding SelectStaticImageCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />
                <Button
                    Grid.Column="1"
                    Text="{loc:AppText Key=Ui028}"
                    Command="{Binding SelectAnimationCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>
            <SearchBar
                Grid.Row="1"
                Placeholder="{loc:AppText Key=Ui297}"
                SemanticProperties.Description="{loc:AppText Key=Ui295}"
                Text="{Binding SearchText, Mode=TwoWay}" />
        </Grid>

        <CollectionView
            x:Name="CatalogView"
            Grid.Row="2"
            ItemsSource="{Binding CatalogItems}"
            Scrolled="OnCatalogScrolled"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="8">
                    <Label Text="{loc:AppText Key=Ui189}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{loc:AppText Key=Ui349}" Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="builtins:BuiltInAssetListItem">
                    <Border Margin="0,0,0,1" Style="{StaticResource ActionCardBorderStyle}">
                        <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="12" MinimumHeightRequest="92">
                            <controls:BuiltInPreviewView
                                HeightRequest="82"
                                WidthRequest="66"
                                IsAnimationPlaying="{Binding IsAnimationPlaying}"
                                SemanticDescription="{Binding Title, StringFormat='{loc:AppText Key=Ui419}'}"
                                Source="{Binding PreviewResourceName}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold" />
                                <Label Text="{Binding IdLabel}" Style="{StaticResource TinyLabelStyle}" />
                                <Label Text="{Binding StatusLabel}" Style="{StaticResource MutedLabelStyle}" />
                                <Button
                                    Text="{loc:AppText Key=Ui085}"
                                    Clicked="OnDetailsClicked"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="Start"
                                    Style="{StaticResource CompactButtonStyle}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Button
                                    Text="{Binding FavoriteLabel}"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    SemanticProperties.Description="{Binding FavoriteAccessibilityLabel}"
                                    Style="{StaticResource CompactButtonStyle}" />
                                <Button
                                    Text="{loc:AppText Key=Ui302}"
                                    Command="{Binding SendCommand}"
                                    SemanticProperties.Hint="{loc:AppText Key=Ui306}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <VerticalStackLayout Padding="8,18,8,28" Spacing="5">
                    <Label Text="{loc:AppText Key=Ui324}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label
                        Text="{loc:AppText Key=Ui341}"
                        Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding TransportReadinessText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>
