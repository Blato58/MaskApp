<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Scenes.SceneStudioPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    xmlns:scenes="clr-namespace:MaskApp.Core.Features.Scenes;assembly=MaskApp.Core"
    x:DataType="scenes:SceneStudioViewModel"
    Title="{loc:AppText Key=Ui293}"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{loc:AppText Key=Ui293}" Style="{StaticResource PageTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui063}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </Grid>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui289}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Picker
                        x:Name="ScenePicker"
                        Title="{loc:AppText Key=Ui285}"
                        ItemsSource="{Binding Scenes}"
                        ItemDisplayBinding="{Binding DisplayName, x:DataType=scenes:PerformanceScene}"
                        SelectedIndexChanged="OnSceneSelected" />
                    <Entry Placeholder="{loc:AppText Key=Ui291}" Text="{Binding SceneName, Mode=TwoWay}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Entry Placeholder="#A78BFA" Text="{Binding SceneColorHex, Mode=TwoWay}" />
                        <Picker Grid.Column="1" Title="{loc:AppText Key=Ui111}" ItemsSource="{Binding FailurePolicies}" SelectedItem="{Binding FailurePolicy, Mode=TwoWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="7">
                        <Button Text="{loc:AppText Key=Ui180}" Command="{Binding NewSceneCommand}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui274}" Command="{Binding SaveSceneCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui095}" Command="{Binding DuplicateSceneCommand}" />
                        <Button Grid.Column="3" Text="{loc:AppText Key=Ui081}" Command="{Binding DeleteSceneCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui021}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui198}" Style="{StaticResource MutedLabelStyle}" />
                    <Picker Title="{loc:AppText Key=Ui323}" ItemsSource="{Binding StepKinds}" SelectedItem="{Binding NewStepKind, Mode=TwoWay}" />
                    <Picker
                        Title="{loc:AppText Key=Ui157}"
                        ItemsSource="{Binding ContentOptions}"
                        ItemDisplayBinding="{Binding Title, x:DataType=gallery:GalleryItem}"
                        SelectedItem="{Binding SelectedContentItem, Mode=TwoWay}"
                        IsVisible="{Binding NeedsContentItem}" />
                    <VerticalStackLayout IsVisible="{Binding NeedsValue}" Spacing="3">
                        <Label Text="{Binding StepValue, StringFormat='{loc:AppText Key=Ui433}'}" Style="{StaticResource TinyLabelStyle}" />
                        <Stepper Minimum="1" Maximum="100" Increment="1" Value="{Binding StepValue, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout IsVisible="{Binding NeedsDuration}" Spacing="3">
                        <Label Text="{Binding StepDurationMilliseconds, StringFormat='{loc:AppText Key=Ui434}'}" Style="{StaticResource TinyLabelStyle}" />
                        <Stepper Minimum="16" Maximum="30000" Increment="100" Value="{Binding StepDurationMilliseconds, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <Grid IsVisible="{Binding NeedsRepeat}" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Picker
                            Title="{loc:AppText Key=Ui261}"
                            ItemsSource="{Binding RepeatTargets}"
                            ItemDisplayBinding="{Binding Title, x:DataType=scenes:SceneStepRow}"
                            SelectedItem="{Binding SelectedRepeatTarget, Mode=TwoWay}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding RepeatCount, StringFormat='{loc:AppText Key=Ui432}'}" Style="{StaticResource TinyLabelStyle}" />
                            <Stepper Minimum="2" Maximum="10" Value="{Binding RepeatCount, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="{loc:AppText Key=Ui013}" Clicked="OnAddStepClicked" Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui292}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{loc:AppText Key=Ui161}" Style="{StaticResource MutedLabelStyle}" />
                    <CollectionView ItemsSource="{Binding StepRows}" SelectionMode="None" HeightRequest="330">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="scenes:SceneStepRow">
                                <Border Padding="10" Margin="0,0,0,7" Stroke="#64748B" BackgroundColor="#111827">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStepTapped" CommandParameter="{Binding .}" />
                                        <DragGestureRecognizer DragStarting="OnStepDragStarting" />
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnStepDropped" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Label Text="{Binding DisplayIndex}" FontSize="20" FontAttributes="Bold" TextColor="#52E3FF" VerticalTextAlignment="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                                            <Label Text="{Binding Summary}" Style="{StaticResource TinyLabelStyle}" LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="7">
                        <Button Text="{loc:AppText Key=Ui095}" Clicked="OnDuplicateStepClicked" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui081}" Clicked="OnDeleteStepClicked" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui177}" Clicked="OnMoveStepEarlierClicked" />
                        <Button Grid.Column="3" Text="{loc:AppText Key=Ui178}" Clicked="OnMoveStepLaterClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{loc:AppText Key=Ui358}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{Binding ValidationSummary}" FontAttributes="Bold" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ValidationIssues}" Spacing="5">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="scenes:SceneValidationIssue">
                                <Label Text="{Binding Message}" TextColor="#FCA5A5" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button Text="{loc:AppText Key=Ui256}" Command="{Binding RehearseSceneCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui326}" Command="{Binding StopCommand}" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui045}" Command="{Binding BlackoutCommand}" BackgroundColor="#7F1D1D" TextColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:AppText Key=Ui309}" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Picker
                        x:Name="SetlistPicker"
                        Title="{loc:AppText Key=Ui286}"
                        ItemsSource="{Binding Setlists}"
                        ItemDisplayBinding="{Binding DisplayName, x:DataType=scenes:PerformanceSetlist}"
                        SelectedIndexChanged="OnSetlistSelected" />
                    <Entry Placeholder="{loc:AppText Key=Ui310}" Text="{Binding SetlistName, Mode=TwoWay}" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="7">
                        <Button Text="{loc:AppText Key=Ui180}" Command="{Binding NewSetlistCommand}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui274}" Command="{Binding SaveSetlistCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui095}" Command="{Binding DuplicateSetlistCommand}" />
                        <Button Grid.Column="3" Text="{loc:AppText Key=Ui081}" Command="{Binding DeleteSetlistCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Picker
                            Title="{loc:AppText Key=Ui290}"
                            ItemsSource="{Binding Scenes}"
                            ItemDisplayBinding="{Binding DisplayName, x:DataType=scenes:PerformanceScene}"
                            SelectedItem="{Binding SelectedCueScene, Mode=TwoWay}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui015}" Clicked="OnAddCueClicked" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding CueRows}" SelectionMode="None" HeightRequest="270">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="scenes:SetlistCueRow">
                                <Border Padding="10" Margin="0,0,0,7" Stroke="#64748B" BackgroundColor="#111827">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCueTapped" CommandParameter="{Binding .}" />
                                        <DragGestureRecognizer DragStarting="OnCueDragStarting" />
                                        <DropGestureRecognizer AllowDrop="True" Drop="OnCueDropped" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Label Text="{Binding DisplayIndex}" FontSize="20" FontAttributes="Bold" TextColor="#A78BFA" VerticalTextAlignment="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Cue.Label}" FontAttributes="Bold" />
                                            <Label Text="{Binding SceneName}" Style="{StaticResource TinyLabelStyle}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="7">
                        <Button Text="{loc:AppText Key=Ui095}" Clicked="OnDuplicateCueClicked" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui081}" Clicked="OnDeleteCueClicked" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui177}" Clicked="OnMoveCueEarlierClicked" />
                        <Button Grid.Column="3" Text="{loc:AppText Key=Ui178}" Clicked="OnMoveCueLaterClicked" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="{loc:AppText Key=Ui356}" Command="{Binding ActivateSetlistCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui354}" Command="{Binding UsePagesCommand}" />
                    </Grid>
                    <Label Text="{Binding SetlistPositionText}" Style="{StaticResource MutedLabelStyle}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button Text="{loc:AppText Key=Ui238}" Command="{Binding PreviousCueCommand}" />
                        <Button Grid.Column="1" Text="{loc:AppText Key=Ui348}" Command="{Binding TriggerCueCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="2" Text="{loc:AppText Key=Ui185}" Command="{Binding NextCueCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
