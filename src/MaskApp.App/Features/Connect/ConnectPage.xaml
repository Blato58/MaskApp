<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Connect.ConnectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:connect="clr-namespace:MaskApp.Core.Features.Connect;assembly=MaskApp.Core"
    xmlns:mask="clr-namespace:MaskApp.Core.Features.MaskControl;assembly=MaskApp.Core"
    x:DataType="connect:ConnectViewModel"
    Title="Connect"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Connect" Style="{StaticResource PageTitleLabelStyle}" />
                            <Label Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Border
                            Grid.Column="1"
                            Style="{StaticResource StatusPillBorderStyle}"
                            Stroke="{Binding ConnectionState, Converter={StaticResource TransportStateColorConverter}}">
                            <Label
                                Text="{Binding ConnectionState}"
                                TextColor="{Binding ConnectionState, Converter={StaticResource TransportStateColorConverter}}"
                                Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Scan" Command="{Binding StartScanCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Stop" Command="{Binding StopScanCommand}" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource BrightButtonStyle}" />
                        <Button Grid.Column="1" Text="Disconnect" Command="{Binding DisconnectCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Known mask" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding AutoConnectStatusText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="Connect now"
                            Command="{Binding StartAutoConnectCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource CompactPanelBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                            <Label Text="Mask" Style="{StaticResource TinyLabelStyle}" />
                            <Label Grid.Column="1" Text="{Binding LastKnownMaskText}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="Scope" Style="{StaticResource TinyLabelStyle}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="Foreground only while the app is open." Style="{StaticResource MutedLabelStyle}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Switch IsToggled="{Binding AutoConnectEnabled, Mode=TwoWay}" />
                            <Label Text="Auto-connect" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Switch IsToggled="{Binding RememberLastDeviceEnabled, Mode=TwoWay}" />
                            <Label Text="Remember" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <Button
                            Grid.Column="2"
                            Text="Forget"
                            Command="{Binding ForgetKnownMaskCommand}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="Nearby masks" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding Devices.Count, StringFormat='{}{0} found'}" Style="{StaticResource TinyLabelStyle}" />
                    </Grid>
                    <CollectionView
                        Grid.Row="1"
                        HeightRequest="210"
                        ItemsSource="{Binding Devices}"
                        SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                        SelectionMode="Single">
                        <CollectionView.EmptyView>
                            <Grid Padding="18">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                    <Image HeightRequest="64" Source="mask_neon.svg" WidthRequest="64" />
                                    <Label
                                        HorizontalTextAlignment="Center"
                                        Text="No masks discovered"
                                        Style="{StaticResource MutedLabelStyle}" />
                                </VerticalStackLayout>
                            </Grid>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="connect:DiscoveredMaskDevice">
                                <Border
                                    Margin="0,0,0,10"
                                    Style="{StaticResource CompactPanelBorderStyle}"
                                    Stroke="{StaticResource AccentColor}">
                                    <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                        <Image Grid.RowSpan="2" HeightRequest="44" Source="mask_neon.svg" WidthRequest="44" />
                                        <Label Grid.Column="1" Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Grid.Column="2" Text="{Binding SignalStrength}" TextColor="{StaticResource AccentGreenColor}" />
                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            Text="{Binding Id}"
                                            Style="{StaticResource TinyLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <VerticalStackLayout
                x:Name="MaskControls"
                x:DataType="mask:MaskControlViewModel"
                Spacing="16">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                            <Label Text="Device controls" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Border
                                Grid.Column="1"
                                Style="{StaticResource StatusPillBorderStyle}"
                                Stroke="{Binding TransportState, Converter={StaticResource TransportStateColorConverter}}">
                                <Label
                                    Text="{Binding TransportState}"
                                    TextColor="{Binding TransportState, Converter={StaticResource TransportStateColorConverter}}"
                                    Style="{StaticResource ChipLabelStyle}" />
                            </Border>
                            <Label
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding TransportStatusText}"
                                Style="{StaticResource MutedLabelStyle}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Padding="18"
                            BackgroundColor="#03050A"
                            Stroke="{StaticResource AccentColor}"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid HeightRequest="104" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <BoxView Color="#52E3FF" Opacity="{Binding PreviewOpacity}" />
                                <BoxView Grid.Column="1" Color="#FACC15" Opacity="{Binding PreviewOpacity}" />
                                <BoxView Grid.Column="2" Color="#FF3D8B" Opacity="{Binding PreviewOpacity}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                            <Label Text="Brightness" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Brightness, StringFormat='{}{0}%'}" Style="{StaticResource MetricLabelStyle}" />
                            <Slider
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Minimum="1"
                                Maximum="100"
                                Value="{Binding Brightness, Mode=TwoWay}" />
                            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Text="Apply" Command="{Binding ApplyBrightnessCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Grid.Column="1" Text="{Binding PowerButtonText}" Command="{Binding TogglePowerCommand}" Style="{StaticResource DangerButtonStyle}" />
                            </Grid>
                        </Grid>

                        <VerticalStackLayout Grid.Row="3" Spacing="8">
                            <Label Text="Effects" Style="{StaticResource SectionTitleLabelStyle}" />
                            <FlexLayout
                                AlignItems="Start"
                                BindableLayout.ItemsSource="{Binding EffectPresets}"
                                Direction="Row"
                                Wrap="Wrap">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="mask:MaskEffectPreset">
                                        <Button
                                            Margin="0,0,8,8"
                                            Text="{Binding Name}"
                                            Command="{Binding ApplyCommand}"
                                            Style="{StaticResource NeonBlueButtonStyle}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                            <Label Text="{Binding CurrentEffectName}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>

                        <Label Grid.Row="4" Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CompactPanelBorderStyle}">
                    <Grid
                        RowDefinitions="Auto,Auto"
                        RowSpacing="8">
                        <Label Text="Transports" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Grid
                            Grid.Row="1"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="10"
                            RowDefinitions="Auto,Auto,Auto,Auto"
                            RowSpacing="4">
                            <Label Text="Transport" Style="{StaticResource TinyLabelStyle}" />
                            <Label Grid.Column="1" Text="{Binding ActiveTransportText}" />

                            <Label Grid.Row="1" Text="Command" Style="{StaticResource TinyLabelStyle}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding LastCommandText}" />

                            <Label Grid.Row="2" Text="Payload" Style="{StaticResource TinyLabelStyle}" />
                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                FontSize="12"
                                LineBreakMode="CharacterWrap"
                                Text="{Binding LastPayloadHex}"
                                TextColor="{StaticResource SecondaryTextColor}" />

                            <Label Grid.Row="3" Text="Status" Style="{StaticResource TinyLabelStyle}" />
                            <Label
                                Grid.Row="3"
                                Grid.Column="1"
                                LineBreakMode="WordWrap"
                                Text="{Binding LastTransportStatusText}" />
                        </Grid>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
