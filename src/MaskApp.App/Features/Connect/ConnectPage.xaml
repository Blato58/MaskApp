<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Connect.ConnectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:connect="clr-namespace:MaskApp.Core.Features.Connect;assembly=MaskApp.Core"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:mask="clr-namespace:MaskApp.Core.Features.MaskControl;assembly=MaskApp.Core"
    x:DataType="connect:ConnectViewModel"
    Title="{x:Static loc:AppText.Device}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="18">
            <VerticalStackLayout Spacing="2">
                <Label Text="{x:Static loc:AppText.Device}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Connection, live controls, and evidence from the active mask." Style="{StaticResource TinyLabelStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                            <controls:ConnectionStatusView
                                State="{Binding ConnectionState}"
                                StateText="{Binding ConnectionHeadline}"
                                DetailText="{Binding ConnectionDetailText}" />
                            <Label Text="{Binding DeviceNameText}" FontSize="26" FontAttributes="Bold" MaxLines="2" />
                        </VerticalStackLayout>
                        <Image Grid.Column="1" Source="mask_neon.svg" HeightRequest="88" WidthRequest="88" SemanticProperties.Description="LED mask" />
                    </Grid>
                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Signal" Style="{StaticResource TinyLabelStyle}" />
                            <Label Text="{Binding DeviceSignalText}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Transport" Style="{StaticResource TinyLabelStyle}" />
                            <Label Text="{Binding TransportText}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Reconnect" Command="{Binding StartAutoConnectCommand}" Style="{StaticResource SecondaryButtonStyle}" SemanticProperties.Description="Reconnect remembered mask" />
                        <Button Grid.Column="1" Text="Disconnect" Command="{Binding DisconnectCommand}" IsVisible="{Binding CanDisconnect}" Style="{StaticResource DangerButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="8">
                <Label Text="Last Preflight" Style="{StaticResource SectionTitleLabelStyle}" />
                <controls:ReadinessCardView
                    StatusText="{Binding PreflightStatusText}"
                    Summary="{Binding PreflightSummaryText}"
                    Icon="{Binding PreflightIcon}"
                    AccentColor="{Binding PreflightColorHex}" />
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="MaskControls" x:DataType="mask:MaskControlViewModel" Spacing="18">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Brightness" Style="{StaticResource ModeTitleLabelStyle}" />
                                <Label Text="Applies to the connected mask." Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Brightness, StringFormat='{}{0}%'}" Style="{StaticResource MetricLabelStyle}" VerticalTextAlignment="Center" />
                        </Grid>
                        <Slider Minimum="1" Maximum="100" Value="{Binding Brightness, Mode=TwoWay}" SemanticProperties.Description="Mask brightness percentage" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                            <Button Text="25%" Command="{Binding SetBrightness25Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="1" Text="50%" Command="{Binding SetBrightness50Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="2" Text="75%" Command="{Binding SetBrightness75Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="3" Text="100%" Command="{Binding SetBrightness100Command}" Style="{StaticResource ModeButtonStyle}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button Text="Apply" Command="{Binding ApplyBrightnessCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Grid.Column="1" Text="Blackout" Command="{Binding BlackoutCommand}" Style="{StaticResource DangerButtonStyle}" />
                            <Button Grid.Column="2" Text="Restore" Command="{Binding RestoreBrightnessCommand}" Style="{StaticResource BrightButtonStyle}" />
                        </Grid>
                        <Label Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Firmware mode speed" Style="{StaticResource ModeTitleLabelStyle}" />
                                <Label Text="Affects stock text and animation SPEED modes." Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding PlaybackSpeed}" Style="{StaticResource MetricLabelStyle}" VerticalTextAlignment="Center" />
                        </Grid>
                        <Slider Minimum="1" Maximum="100" Value="{Binding PlaybackSpeed, Mode=TwoWay}" SemanticProperties.Description="Firmware mode speed" />
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                            <Button Text="25" Command="{Binding SetPlaybackSpeed25Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="1" Text="50" Command="{Binding SetPlaybackSpeed50Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="2" Text="75" Command="{Binding SetPlaybackSpeed75Command}" Style="{StaticResource ModeButtonStyle}" />
                            <Button Grid.Column="3" Text="100" Command="{Binding SetPlaybackSpeed100Command}" Style="{StaticResource ModeButtonStyle}" />
                        </Grid>
                        <Button Text="Apply speed" Command="{Binding ApplyPlaybackSpeedCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <controls:SectionHeaderView Title="{x:Static loc:AppText.Connection}" Subtitle="Scan, choose the physical mask, and connect." />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Grid>
                            <Button Text="Scan for masks" Command="{Binding StartScanCommand}" IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Text="Stop scanning" Command="{Binding StopScanCommand}" IsVisible="{Binding IsScanning}" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>
                        <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}" />
                    </Grid>
                    <Label Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" />
                    <CollectionView
                        HeightRequest="210"
                        ItemsSource="{Binding Devices}"
                        SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                        SelectionMode="Single">
                        <CollectionView.EmptyView>
                            <controls:EmptyStateView Icon="◇" Title="No nearby masks" Message="Start a scan and keep the mask awake and close by." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="connect:DiscoveredMaskDevice">
                                <Border Margin="0,0,0,6" Style="{StaticResource ListRowBorderStyle}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList><VisualStateGroup x:Name="CommonStates"><VisualState x:Name="Normal" /><VisualState x:Name="Selected"><VisualState.Setters><Setter Property="BackgroundColor" Value="{StaticResource SelectedSurfaceColor}" /><Setter Property="Stroke" Value="{StaticResource AccentColor}" /><Setter Property="StrokeThickness" Value="1" /></VisualState.Setters></VisualState></VisualStateGroup></VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="10">
                                        <Image Source="mask_neon.svg" HeightRequest="44" WidthRequest="44" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" MaxLines="1" />
                                            <Label Text="Nearby BLE mask" Style="{StaticResource TinyLabelStyle}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding SignalStrength, StringFormat='{}{0} dBm'}" TextColor="{StaticResource ConnectedColor}" VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="Connect selected mask" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <controls:SectionHeaderView Title="Reconnect behavior" Subtitle="Auto-connect runs only while MaskApp is in the foreground." />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Auto-connect" FontAttributes="Bold" />
                            <Label Text="{Binding AutoConnectStatusText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding AutoConnectEnabled, Mode=TwoWay}" />
                    </Grid>
                    <BoxView Style="{StaticResource FullWidthListSeparatorStyle}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Remember last mask" FontAttributes="Bold" />
                            <Label Text="{Binding LastKnownMaskText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding RememberLastDeviceEnabled, Mode=TwoWay}" />
                    </Grid>
                    <Button Text="Forget remembered mask" Command="{Binding ForgetKnownMaskCommand}" IsVisible="{Binding HasKnownMask}" Style="{StaticResource QuietButtonStyle}" />
                    <VerticalStackLayout IsVisible="{Binding HasReconnectHistory}" Spacing="6">
                        <Label Text="Recent connection activity" Style="{StaticResource SectionTitleLabelStyle}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ReconnectHistory}" Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Label Text="{Binding .}" Style="{StaticResource TinyLabelStyle}" MaxLines="2" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="AdvancedToggle" Text="Show diagnostics" Clicked="OnToggleAdvancedClicked" Style="{StaticResource QuietButtonStyle}" />
            <Border x:Name="AdvancedPanel" IsVisible="False" Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <controls:SectionHeaderView Title="{x:Static loc:AppText.Diagnostics}" Subtitle="Observed values only; unavailable telemetry stays explicitly unavailable." />
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                        <Label Text="Firmware" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Column="1" Text="{Binding FirmwareText}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Text="Acknowledgements" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="1" Grid.Column="1" Text="{Binding AcknowledgementText}" FontAttributes="Bold" />
                        <Label Grid.Row="2" Text="Command write" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="2" Grid.Column="1" Text="{Binding CommandWriteText}" FontAttributes="Bold" />
                        <Label Grid.Row="3" Text="Text / face upload" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="3" Grid.Column="1" Text="{Binding UploadCapabilitiesText}" FontAttributes="Bold" />
                        <Label Grid.Row="4" Text="Battery" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="4" Grid.Column="1" Text="{Binding BatteryText}" FontAttributes="Bold" />
                        <Label Grid.Row="5" Text="Prepared slots" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="5" Grid.Column="1" Text="{Binding PreparedSlotText}" FontAttributes="Bold" />
                    </Grid>
                    <Label Text="{Binding PreparedSlotDetailText}" Style="{StaticResource TinyLabelStyle}" />

                    <BoxView Style="{StaticResource FullWidthListSeparatorStyle}" />
                    <Label Text="Transport evidence" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                        <Label Text="Command latency" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Column="1" Text="{Binding LatencyText}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Text="Sustainable cadence" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="1" Grid.Column="1" Text="{Binding CadenceText}" FontAttributes="Bold" />
                        <Label Grid.Row="2" Text="Scheduler" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="2" Grid.Column="1" Text="{Binding SchedulerQueueText}" FontAttributes="Bold" />
                        <Label Grid.Row="3" Text="Last operation" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="3" Grid.Column="1" Text="{Binding SchedulerLastDurationText}" FontAttributes="Bold" />
                        <Label Grid.Row="4" Text="Animation delivery" Style="{StaticResource MutedLabelStyle}" /><Label Grid.Row="4" Grid.Column="1" Text="{Binding AnimationDeliveryText}" FontAttributes="Bold" MaxLines="2" />
                    </Grid>
                    <Label Text="{Binding SchedulerErrorText, StringFormat='Last scheduler error: {0}'}" Style="{StaticResource TinyLabelStyle}" />
                    <VerticalStackLayout IsVisible="{Binding HasRecentRedactedErrors}" Spacing="5">
                        <Label Text="Recent redacted errors" Style="{StaticResource SectionTitleLabelStyle}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentRedactedErrors}" Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Label Text="{Binding .}" Style="{StaticResource TinyLabelStyle}" MaxLines="3" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <BoxView Style="{StaticResource FullWidthListSeparatorStyle}" />
                    <Label Text="Last preflight" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Text="{Binding PreflightStatusText}" TextColor="{Binding PreflightColorHex}" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding PreflightSummaryText}" Style="{StaticResource MutedLabelStyle}" />

                    <Label Text="{Binding DiagnosticsStatusText}" Style="{StaticResource TinyLabelStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Refresh diagnostics" Clicked="OnRefreshDiagnosticsClicked" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Export redacted report" Clicked="OnExportDiagnosticsClicked" Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                    <Button Text="Reset prepared-slot ledger for this mask" Clicked="OnResetPreparedSlotsClicked" IsEnabled="{Binding CanResetPreparedSlots}" Style="{StaticResource DangerButtonStyle}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
