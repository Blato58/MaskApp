<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Connect.ConnectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:connect="clr-namespace:MaskApp.Core.Features.Connect;assembly=MaskApp.Core"
    xmlns:mask="clr-namespace:MaskApp.Core.Features.MaskControl;assembly=MaskApp.Core"
    Title="Connect"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="18">
            <VerticalStackLayout Spacing="6">
                <Label Text="Connect" Style="{StaticResource PageTitleLabelStyle}" />
                <Label Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Bluetooth discovery" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Border
                            Grid.Column="1"
                            Padding="8,3"
                            BackgroundColor="{StaticResource ChipBackgroundColor}"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="{Binding ConnectionState}" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>
                    <Label Grid.Row="1" Text="Scan nearby masks and select the device to connect." Style="{StaticResource MutedLabelStyle}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Scan" Command="{Binding StartScanCommand}" />
                        <Button Grid.Column="1" Text="Stop" Command="{Binding StopScanCommand}" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Connect" Command="{Binding ConnectCommand}" />
                        <Button Grid.Column="1" Text="Disconnect" Command="{Binding DisconnectCommand}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="Discovered devices" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView
                        Grid.Row="1"
                        HeightRequest="190"
                        ItemsSource="{Binding Devices}"
                        SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                        SelectionMode="Single">
                        <CollectionView.EmptyView>
                            <Grid Padding="12">
                                <Label
                                    HorizontalTextAlignment="Center"
                                    Text="No masks discovered"
                                    Style="{StaticResource MutedLabelStyle}" />
                            </Grid>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="connect:DiscoveredMaskDevice">
                                <Grid Padding="0,10" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="{Binding SignalStrength}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Id}" FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <VerticalStackLayout x:Name="MaskControls" Spacing="14">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                            <Label Text="Mask controls" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Border
                                Grid.Column="1"
                                Padding="8,3"
                                BackgroundColor="{StaticResource ChipBackgroundColor}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding TransportState}" Style="{StaticResource ChipLabelStyle}" />
                            </Border>
                            <Label
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Text="{Binding TransportStatusText}"
                                Style="{StaticResource MutedLabelStyle}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Padding="18"
                            BackgroundColor="#111827"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid HeightRequest="96" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <BoxView Color="#38BDF8" Opacity="{Binding PreviewOpacity}" />
                                <BoxView Grid.Column="1" Color="#FACC15" Opacity="{Binding PreviewOpacity}" />
                                <BoxView Grid.Column="2" Color="#F472B6" Opacity="{Binding PreviewOpacity}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                            <Label Text="Brightness" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Brightness, StringFormat='{}{0}%'}" Style="{StaticResource MutedLabelStyle}" />
                            <Slider
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Minimum="1"
                                Maximum="100"
                                Value="{Binding Brightness, Mode=TwoWay}" />
                            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button Text="Apply" Command="{Binding ApplyBrightnessCommand}" />
                                <Button Grid.Column="1" Text="{Binding PowerButtonText}" Command="{Binding TogglePowerCommand}" />
                            </Grid>
                        </Grid>

                        <VerticalStackLayout Grid.Row="3" Spacing="8">
                            <Label Text="Effects" FontAttributes="Bold" />
                            <FlexLayout
                                AlignItems="Start"
                                BindableLayout.ItemsSource="{Binding EffectPresets}"
                                Direction="Row"
                                Wrap="Wrap">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="mask:MaskEffectPreset">
                                        <Button
                                            Margin="0,0,8,8"
                                            Text="{Binding Name}"
                                            Command="{Binding ApplyCommand}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                            <Label Text="{Binding CurrentEffectName}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>

                        <Label Grid.Row="4" Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid
                        RowDefinitions="Auto,Auto"
                        RowSpacing="8">
                        <Label Text="Diagnostics" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Grid
                        Grid.Row="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="4">
                            <Label Text="Transport" Style="{StaticResource MutedLabelStyle}" />
                            <Label Grid.Column="1" Text="{Binding ActiveTransportText}" />

                            <Label Grid.Row="1" Text="Command" Style="{StaticResource MutedLabelStyle}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding LastCommandText}" />

                            <Label Grid.Row="2" Text="Payload" Style="{StaticResource MutedLabelStyle}" />
                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                FontSize="12"
                                LineBreakMode="CharacterWrap"
                                Text="{Binding LastPayloadHex}" />

                            <Label Grid.Row="3" Text="Status" Style="{StaticResource MutedLabelStyle}" />
                            <Label
                                Grid.Row="3"
                                Grid.Column="1"
                                LineBreakMode="WordWrap"
                                Text="{Binding LastTransportStatusText}" />
                        </Grid>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
