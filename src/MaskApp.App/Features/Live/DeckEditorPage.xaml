<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Live.DeckEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    xmlns:live="clr-namespace:MaskApp.Core.Features.Live;assembly=MaskApp.Core"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="live:LiveViewModel"
    Title="{loc:Translate DeckEditorTitle}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <VerticalStackLayout Spacing="2">
            <Label Text="{loc:Translate DeckEditorTitle}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="{Binding SelectedDeckName}" Style="{StaticResource SectionTitleLabelStyle}" />
        </VerticalStackLayout>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label Text="{loc:Translate ContentInheritsAppearance}" Style="{StaticResource MutedLabelStyle}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="{x:Static loc:AppText.AddFromLibrary}" Clicked="OnAddClicked" MinimumHeightRequest="48" />
        </Grid>
        <CollectionView Grid.Row="2" ItemsSource="{Binding Actions}" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="{loc:Translate NoDeckActions}" Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryPageShortcutCard">
                    <Grid Padding="0,12" RowDefinitions="Auto,Auto" RowSpacing="8" MinimumHeightRequest="104">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Label}" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding FastSlotStatusText}" Style="{StaticResource TinyLabelStyle}" MaxLines="2" />
                        </VerticalStackLayout>
                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                            <Button Text="{loc:Translate Prepare}" Command="{Binding PrepareCommand}" IsVisible="{Binding IsFastSlotCapable}" MinimumHeightRequest="48" />
                            <Button Grid.Column="1" Text="↑" Command="{Binding MoveEarlierCommand}" MinimumHeightRequest="48" SemanticProperties.Description="{loc:Translate MoveEarlier}" />
                            <Button Grid.Column="2" Text="↓" Command="{Binding MoveLaterCommand}" MinimumHeightRequest="48" SemanticProperties.Description="{loc:Translate MoveLater}" />
                            <Button Grid.Column="3" Text="{loc:Translate Remove}" Command="{Binding RemoveCommand}" Style="{StaticResource DangerButtonStyle}" MinimumHeightRequest="48" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <VerticalStackLayout Grid.Row="3" Spacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{x:Static loc:AppText.RequireHoldForActions}" FontAttributes="Bold" />
                    <Label Text="{loc:Translate LiveHoldStageUnchanged}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
                <Switch Grid.Column="1" IsToggled="{Binding RequireHoldForActions, Mode=TwoWay}" SemanticProperties.Description="{loc:Translate DeckHoldDescription}" />
            </Grid>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Text="{loc:Translate PrepareDeck}" Command="{Binding Pages.PreparePageCommand}" />
                <Button Grid.Column="1" Text="{loc:Translate DeckSettings}" Clicked="OnToggleSettingsClicked" />
                <Button Grid.Column="2" Text="{x:Static loc:AppText.Preflight}" Clicked="OnPreflightClicked" />
            </Grid>
            <Border x:Name="DeckSettingsPanel" IsVisible="False" Style="{StaticResource PanelBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Entry Placeholder="{loc:Translate DeckName}" Text="{Binding Pages.PageTitleDraft, Mode=TwoWay}" />
                    <Button Text="{loc:Translate SaveName}" Command="{Binding Pages.SavePageTitleCommand}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                        <Button Text="{loc:Translate Earlier}" Command="{Binding Pages.MoveSelectedPageEarlierCommand}" />
                        <Button Grid.Column="1" Text="{loc:Translate Color}" Command="{Binding Pages.CyclePageColorCommand}" />
                        <Button Grid.Column="2" Text="{loc:Translate Later}" Command="{Binding Pages.MoveSelectedPageLaterCommand}" />
                    </Grid>
                    <Button Text="{x:Static loc:AppText.DeleteDeck}" Clicked="OnDeleteDeckClicked" Style="{StaticResource DangerButtonStyle}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
