<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Live.ContentPickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:gallery="clr-namespace:MaskApp.Core.Features.Gallery;assembly=MaskApp.Core"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="gallery:PagesViewModel"
    Title="{x:Static loc:AppText.AddFromLibrary}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="2">
                <Label Text="{x:Static loc:AppText.AddFromLibrary}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
                <Label Text="{loc:Translate ContentInheritsAppearance}" Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="{x:Static loc:AppText.Done}" Clicked="OnDoneClicked" MinimumHeightRequest="48" />
        </Grid>
        <CollectionView Grid.Row="1" ItemsSource="{Binding AvailableItems}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gallery:GalleryAvailableItemCard">
                    <Grid Padding="0,10" ColumnDefinitions="*,Auto" MinimumHeightRequest="68">
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding Subtitle}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="{x:Static loc:AppText.Add}" Command="{Binding AddCommand}" MinimumHeightRequest="48" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
