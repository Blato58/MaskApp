<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.React.ReactPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:builtins="clr-namespace:MaskApp.Core.Features.BuiltIns;assembly=MaskApp.Core"
    xmlns:presets="clr-namespace:MaskApp.Core.Features.TextPresets;assembly=MaskApp.Core"
    xmlns:react="clr-namespace:MaskApp.Core.Features.React;assembly=MaskApp.Core"
    x:DataType="react:ReactViewModel"
    Title="React"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Reaction Deck" Style="{StaticResource PageTitleLabelStyle}" />
                            <Label Text="{Binding ReadinessText}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            Text="Text Composer"
                            Clicked="OnOpenTextClicked"
                            Style="{StaticResource NeonBlueButtonStyle}" />
                        <ActivityIndicator
                            Grid.Column="2"
                            IsRunning="{Binding IsSending}"
                            IsVisible="{Binding IsSending}"
                            VerticalOptions="Center" />
                    </Grid>

                    <FlexLayout
                        Grid.Row="1"
                        AlignItems="Start"
                        BindableLayout.ItemsSource="{Binding FilterOptions}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="react:ReactFilterOption">
                                <Button
                                    Margin="0,0,8,8"
                                    Padding="12,7"
                                    Text="{Binding Label}"
                                    Clicked="OnFilterClicked"
                                    CommandParameter="{Binding .}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Label
                        Grid.Row="2"
                        Text="{Binding SelectedFilter.Label, StringFormat='Showing {0} reactions'}"
                        Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>

            <VerticalStackLayout
                BindableLayout.ItemsSource="{Binding PresetGroups}"
                Spacing="14">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="presets:TextPresetGroup">
                        <Border Style="{StaticResource PanelBorderStyle}">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Title}" Style="{StaticResource SectionTitleLabelStyle}" />
                                    <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                                        <Label Text="{Binding Cards.Count, StringFormat='{}{0} presets'}" Style="{StaticResource ChipLabelStyle}" />
                                    </Border>
                                </Grid>
                                <FlexLayout
                                    Grid.Row="1"
                                    AlignItems="Stretch"
                                    BindableLayout.ItemsSource="{Binding Cards}"
                                    Direction="Row"
                                    Wrap="Wrap">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="presets:TextPresetCard">
                                            <Border
                                                Margin="0,0,10,10"
                                                MinimumHeightRequest="104"
                                                MinimumWidthRequest="158"
                                                Style="{StaticResource ActionCardBorderStyle}"
                                                Stroke="{Binding ColorHex}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SendCommand}" />
                                                </Border.GestureRecognizers>
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <BoxView
                                                            Color="{Binding ColorHex}"
                                                            HeightRequest="18"
                                                            WidthRequest="18"
                                                            VerticalOptions="Center" />
                                                        <Label Grid.Column="1" Text="{Binding DisplayName}" FontAttributes="Bold" />
                                                    </Grid>
                                                    <Label
                                                        Grid.Row="1"
                                                        Text="{Binding InputText}"
                                                        TextColor="{Binding ColorHex}"
                                                        FontAttributes="Bold"
                                                        FontSize="16" />
                                                    <Label
                                                        Grid.Row="2"
                                                        IsVisible="{Binding HasMaskTextDifference}"
                                                        Text="{Binding MaskTextWarning}"
                                                        Style="{StaticResource TinyLabelStyle}" />
                                                    <Label Grid.Row="3" Text="{Binding CategoryText}" Style="{StaticResource TinyLabelStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Label Text="Always ready" Style="{StaticResource SectionTitleLabelStyle}" />
                    <FlexLayout
                        Grid.Row="1"
                        AlignItems="Stretch"
                        BindableLayout.ItemsSource="{Binding PinnedCards}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="react:ReactReactionCard">
                                <Border
                                    Margin="0,0,10,10"
                                    MinimumHeightRequest="92"
                                    MinimumWidthRequest="156"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SendCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Border
                                                BackgroundColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}"
                                                HeightRequest="38"
                                                Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                StrokeThickness="1"
                                                WidthRequest="48">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Label
                                                    HorizontalTextAlignment="Center"
                                                    Text="{Binding Id, Converter={StaticResource QuickActionIconConverter}}"
                                                    TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                    VerticalTextAlignment="Center"
                                                    FontSize="11"
                                                    FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="1" Text="{Binding Label}" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                        </Grid>
                                        <Label Grid.Row="1" Text="{Binding Caption}" FontAttributes="Bold" FontSize="16" VerticalTextAlignment="Center" />
                                        <Label
                                            Grid.Row="2"
                                            TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                            Text="Tap to send"
                                            Style="{StaticResource TinyLabelStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                    <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <Label Text="{Binding CommandReadinessText}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="1" Text="{Binding TextReadinessText}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="2" Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <VerticalStackLayout
                BindableLayout.ItemsSource="{Binding Groups}"
                Spacing="14">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="react:ReactReactionGroup">
                        <Border
                            Style="{StaticResource PanelBorderStyle}"
                            Stroke="{Binding Category, Converter={StaticResource QuickActionAccentColorConverter}}">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Title}" Style="{StaticResource SectionTitleLabelStyle}" />
                                    <Border
                                        Grid.Column="1"
                                        BackgroundColor="{Binding Category, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}"
                                        Stroke="{Binding Category, Converter={StaticResource QuickActionAccentColorConverter}}"
                                        Style="{StaticResource StatusPillBorderStyle}">
                                        <Label
                                            Text="{Binding Cards.Count, StringFormat='{}{0} cards'}"
                                            TextColor="{Binding Category, Converter={StaticResource QuickActionAccentColorConverter}}"
                                            Style="{StaticResource ChipLabelStyle}" />
                                    </Border>
                                </Grid>
                                <FlexLayout
                                    Grid.Row="1"
                                    AlignItems="Stretch"
                                    BindableLayout.ItemsSource="{Binding Cards}"
                                    Direction="Row"
                                    Wrap="Wrap">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="react:ReactReactionCard">
                                            <Border
                                                Margin="0,0,10,10"
                                                MinimumHeightRequest="86"
                                                MinimumWidthRequest="148"
                                                Style="{StaticResource ActionCardBorderStyle}"
                                                Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SendCommand}" />
                                                </Border.GestureRecognizers>
                                                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="5">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <Label
                                                            Text="{Binding Id, Converter={StaticResource QuickActionIconConverter}}"
                                                            TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                            FontAttributes="Bold"
                                                            VerticalTextAlignment="Center" />
                                                        <Label Grid.Column="1" Text="{Binding Label}" FontAttributes="Bold" />
                                                    </Grid>
                                                    <Label
                                                        Grid.Row="1"
                                                        Text="{Binding Caption}"
                                                        TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                        FontAttributes="Bold"
                                                        FontSize="16"
                                                        VerticalTextAlignment="Center" />
                                                    <Label Grid.Row="2" Text="Tap to send" Style="{StaticResource TinyLabelStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="Favorite Faces" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Label Grid.Row="1" Text="{Binding FavoriteBuiltInsHintText}" Style="{StaticResource MutedLabelStyle}" />
                    <FlexLayout
                        Grid.Row="2"
                        AlignItems="Stretch"
                        BindableLayout.ItemsSource="{Binding FavoriteBuiltIns}"
                        Direction="Row"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="builtins:BuiltInAssetAction">
                                <Border
                                    Margin="0,0,10,10"
                                    MinimumWidthRequest="148"
                                    Style="{StaticResource ActionCardBorderStyle}"
                                    Stroke="{StaticResource AccentBlueColor}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SendCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Label Text="{Binding Label}" FontAttributes="Bold" TextColor="{StaticResource AccentBlueColor}" />
                                        <Label Grid.Row="1" Text="{Binding Caption}" Style="{StaticResource TinyLabelStyle}" />
                                        <Button
                                            Grid.Row="2"
                                            Text="Send"
                                            Command="{Binding SendCommand}"
                                            Style="{StaticResource NeonBlueButtonStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource CompactPanelBorderStyle}">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                    <Label Text="Last" Style="{StaticResource TinyLabelStyle}" />
                    <Label Grid.Column="1" Text="{Binding LastActionText}" FontAttributes="Bold" />
                    <Label Grid.Row="1" Text="Status" Style="{StaticResource TinyLabelStyle}" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
