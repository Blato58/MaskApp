<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Stage.StageModePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    xmlns:stage="clr-namespace:MaskApp.Core.Features.Stage;assembly=MaskApp.Core"
    x:Name="RootPage"
    x:DataType="stage:StageModeViewModel"
    Title="{x:Static loc:AppText.Stage}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#000000">
    <Grid RowDefinitions="Auto,*,Auto" Padding="12,10,12,12" RowSpacing="10">
        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="1">
                    <Label Text="{Binding LockStatusText}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource ConnectedColor}" CharacterSpacing="1" />
                    <Label Text="{Binding PageTitle}" FontSize="28" FontAttributes="Bold" LineBreakMode="TailTruncation" MaxLines="1" />
                    <Label Text="{Binding PagePositionText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Button
                        Text="{loc:Translate HoldToExit}"
                        Pressed="OnUnlockPressed"
                        Released="OnUnlockReleased"
                        Style="{StaticResource SecondaryButtonStyle}"
                        SemanticProperties.Description="{loc:Translate HoldToExitDescription}" />
                    <Button
                        Text="{loc:Translate ExitEllipsis}"
                        Clicked="OnAccessibleExitClicked"
                        Style="{StaticResource QuietButtonStyle}"
                        SemanticProperties.Description="{loc:Translate AccessibleExitDescription}" />
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Button Text="‹" Command="{Binding PreviousPageCommand}" SemanticProperties.Description="{loc:Translate PreviousCueDeck}" />
                <Button Grid.Column="1" Text="{Binding LayoutButtonText}" Command="{Binding CycleLayoutCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="2" Text="›" Command="{Binding NextPageCommand}" SemanticProperties.Description="{loc:Translate NextCueDeck}" />
            </Grid>

            <Border Grid.Row="2" Padding="10,8" BackgroundColor="{StaticResource SurfaceColor}" Stroke="{Binding ReadinessColorHex}" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                    <Label Text="{Binding ReadinessText}" TextColor="{Binding ReadinessColorHex}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding ReadinessSummary}" Style="{StaticResource TinyLabelStyle}" MaxLines="1" />
                    <Label Grid.Column="2" Text="{Binding ConnectionStatusText}" TextColor="{Binding ConnectionState, Converter={StaticResource TransportStateColorConverter}}" FontAttributes="Bold" FontSize="11" />
                    <Label Grid.Row="1" Grid.ColumnSpan="3" Text="{loc:Translate OutputExplicitOnly}" Style="{StaticResource TinyLabelStyle}" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left" Swiped="OnPageSwiped" />
                <SwipeGestureRecognizer Direction="Right" Swiped="OnPageSwiped" />
            </Grid.GestureRecognizers>

            <CollectionView x:Name="StageTilesView" ItemsSource="{Binding Tiles}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <controls:EmptyStateView Icon="◇" Title="{loc:Translate NoStageCues}" Message="{loc:Translate NoStageCuesDetail}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="stage:StageTile">
                        <Grid Margin="5" MinimumHeightRequest="{Binding TileMinimumHeight, Source={RelativeSource AncestorType={x:Type stage:StageModeViewModel}}, x:DataType=stage:StageModeViewModel}">
                            <Border Style="{StaticResource PerformanceTileBorderStyle}" Stroke="{Binding ColorHex}">
                                <Grid RowDefinitions="96,Auto,Auto,Auto" RowSpacing="5">
                                    <Grid>
                                        <controls:BuiltInPreviewView
                                            IsVisible="{Binding HasResourcePreview}"
                                            IsAnimationPlaying="False"
                                            SemanticDescription="{Binding Label, StringFormat='{0} preview'}"
                                            Source="{Binding PreviewResourceName}" />
                                        <controls:FacePatternPreviewView
                                            IsVisible="{Binding HasFacePreview}"
                                            Pattern="{Binding FacePattern}"
                                            SemanticDescription="{Binding Label, StringFormat='{0} face preview'}" />
                                        <Border IsVisible="{Binding HasAnyPreview, Converter={StaticResource InvertedBoolConverter}}" BackgroundColor="{Binding ColorHex}" Opacity="0.28" Stroke="Transparent">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                            <Label Text="{Binding Subtitle}" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Label Grid.Row="1" Text="{Binding Label}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="2" />
                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <Label Text="{Binding Subtitle}" TextColor="{Binding ColorHex}" FontSize="12" FontAttributes="Bold" MaxLines="1" />
                                        <controls:OperationalStatusBadge Grid.Column="1" Text="{Binding ReadinessBadgeText}" Icon="✓" AccentColor="{Binding ReadinessColorHex}" />
                                    </Grid>
                                    <Label Grid.Row="3" Text="{Binding ReadinessText}" Style="{StaticResource TinyLabelStyle}" HorizontalTextAlignment="Center" MaxLines="2" />
                                </Grid>
                            </Border>
                            <Button
                                Text=""
                                Clicked="OnStageTileClicked"
                                CommandParameter="{Binding .}"
                                IsVisible="{Binding IsHoldAction, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                BorderWidth="0"
                                SemanticProperties.Description="{Binding Label}"
                                SemanticProperties.Hint="{Binding ActionHint}" />
                            <Button
                                Text="{loc:Translate HoldToPlay}"
                                Pressed="OnHoldTilePressed"
                                Released="OnHoldTileReleased"
                                CommandParameter="{Binding .}"
                                IsVisible="{Binding IsHoldAction}"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                BorderWidth="0"
                                TextColor="#FFFFFF"
                                FontSize="12"
                                VerticalOptions="End"
                                SemanticProperties.Description="{Binding Label}"
                                SemanticProperties.Hint="{Binding ActionHint}" />
                            <Button
                                Text="{loc:Translate PlayEllipsis}"
                                Clicked="OnAccessibleHoldTileClicked"
                                CommandParameter="{Binding .}"
                                IsVisible="{Binding IsHoldAction}"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                MinimumHeightRequest="48"
                                ZIndex="3"
                                SemanticProperties.Description="{loc:Translate AccessibleHoldAction}"
                                SemanticProperties.Hint="{loc:Translate AccessibleHoldHint}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border
                IsVisible="{Binding HasConnectionOverlay}"
                BackgroundColor="#F0000000"
                Stroke="{StaticResource DangerColor}"
                StrokeThickness="3"
                Padding="22"
                ZIndex="10">
                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="{Binding ConnectionStatusText}" TextColor="{StaticResource DangerColor}" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ConnectionMessage}" FontSize="17" HorizontalTextAlignment="Center" />
                    <Label Text="{loc:Translate SessionPreservedNoReplay}" Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                    <Button Text="{loc:Translate RecoverWithoutReplay}" Command="{Binding RecoverCommand}" IsEnabled="{Binding CanRecover}" Style="{StaticResource NeonBlueButtonStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="{x:Static loc:AppText.Reconnect}" Clicked="OnReconnectClicked" />
                        <Button Grid.Column="1" Text="{x:Static loc:AppText.OpenDevice}" Clicked="OnOpenDeviceClicked" />
                    </Grid>
                    <Button Text="{loc:Translate RefreshReadiness}" Command="{Binding RefreshReadinessCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button
                        Text="{loc:Translate HoldToExitStage}"
                        Pressed="OnUnlockPressed"
                        Released="OnUnlockReleased"
                        Style="{StaticResource DangerButtonStyle}"
                        SemanticProperties.Description="{loc:Translate HoldToExitDescription}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <controls:OperationalStatusBadge
                    Text="{Binding ActionDeliveryText}"
                    Icon="{Binding ActionDeliveryIcon}"
                    AccentColor="{Binding ActionDeliveryColorHex}"
                    VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding ActionDeliveryDetail}" Style="{StaticResource TinyLabelStyle}" MaxLines="2" VerticalTextAlignment="Center" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Spacing="1">
                    <Label Text="{Binding CurrentCueText}" FontAttributes="Bold" FontSize="14" MaxLines="1" />
                    <Label Text="{Binding NextCueText}" Style="{StaticResource TinyLabelStyle}" MaxLines="1" />
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="{Binding StatusText}" Style="{StaticResource TinyLabelStyle}" HorizontalTextAlignment="End" MaxLines="3" />
            </Grid>
            <Button
                Grid.Row="2"
                Text="{x:Static loc:AppText.Stop}"
                Command="{Binding StopCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                FontSize="22"
                MinimumHeightRequest="64"
                SemanticProperties.Description="{loc:Translate StopDescription}" />
            <Button
                Grid.Row="3"
                Text="{x:Static loc:AppText.Blackout}"
                Command="{Binding BlackoutCommand}"
                Style="{StaticResource EmergencyButtonStyle}"
                SemanticProperties.Description="{loc:Translate BlackoutDescription}" />
        </Grid>
    </Grid>
</ContentPage>
