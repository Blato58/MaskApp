<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Text.TextPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:presets="clr-namespace:MaskApp.Core.Features.TextPresets;assembly=MaskApp.Core"
    xmlns:text="clr-namespace:MaskApp.Core.Features.Text;assembly=MaskApp.Core"
    x:DataType="text:TextUploadViewModel"
    Title="Text"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Text Studio" Style="{StaticResource PageTitleLabelStyle}" />
                            <Label Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                            <Label Text="{Binding CharacterCountText}" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>
                    <Editor
                        Grid.Row="1"
                        AutoSize="TextChanges"
                        FontSize="26"
                        HeightRequest="118"
                        MaxLength="64"
                        Placeholder="LOL"
                        Text="{Binding Text, Mode=TwoWay}" />
                    <Button
                        Grid.Row="2"
                        Text="Send Draft"
                        Command="{Binding SendCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Mode and speed" Style="{StaticResource SectionTitleLabelStyle}" />
                        <ActivityIndicator
                            Grid.Column="1"
                            IsRunning="{Binding IsSending}"
                            IsVisible="{Binding IsSending}" />
                    </Grid>
                    <Picker
                        Grid.Row="1"
                        Title="Layout"
                        ItemsSource="{Binding LayoutModes}"
                        ItemDisplayBinding="{Binding Name, x:DataType=text:TextLayoutModeOption}"
                        SelectedItem="{Binding SelectedLayoutMode, Mode=TwoWay}" />
                    <Picker
                        Grid.Row="2"
                        Title="Animation"
                        ItemsSource="{Binding AnimationModes}"
                        ItemDisplayBinding="{Binding Name, x:DataType=text:TextAnimationModeOption}"
                        SelectedItem="{Binding SelectedAnimationMode, Mode=TwoWay}" />
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Slider
                            Minimum="1"
                            Maximum="100"
                            Value="{Binding Speed, Mode=TwoWay}" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding Speed, StringFormat='{}{0}%'}"
                            Style="{StaticResource MetricLabelStyle}"
                            VerticalTextAlignment="Center" />
                    </Grid>
                    <HorizontalStackLayout Grid.Row="4" Spacing="8">
                        <Switch IsToggled="{Binding IsBold, Mode=TwoWay}" />
                        <Label Text="Bold" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                    <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <Button BackgroundColor="#52E3FF" BorderColor="#52E3FF" Clicked="OnColorClicked" CommandParameter="Cyan" HeightRequest="42" SemanticProperties.Description="Cyan text" Text="" WidthRequest="46" />
                        <Button Grid.Column="1" BackgroundColor="#FFFFFF" BorderColor="#D1D5DB" BorderWidth="1" Clicked="OnColorClicked" CommandParameter="White" HeightRequest="42" SemanticProperties.Description="White text" Text="" WidthRequest="46" />
                        <Button Grid.Column="2" BackgroundColor="#F472B6" BorderColor="#F472B6" Clicked="OnColorClicked" CommandParameter="Pink" HeightRequest="42" SemanticProperties.Description="Pink text" Text="" WidthRequest="46" />
                        <Button Grid.Column="3" BackgroundColor="#FACC15" BorderColor="#FACC15" Clicked="OnColorClicked" CommandParameter="Amber" HeightRequest="42" SemanticProperties.Description="Amber text" Text="" WidthRequest="46" />
                        <Button Grid.Column="4" BackgroundColor="#22C55E" BorderColor="#22C55E" Clicked="OnColorClicked" CommandParameter="Green" HeightRequest="42" SemanticProperties.Description="Green text" Text="" WidthRequest="46" />
                        <Button Grid.Column="5" BackgroundColor="#EF4444" BorderColor="#EF4444" Clicked="OnColorClicked" CommandParameter="Red" HeightRequest="42" SemanticProperties.Description="Red text" Text="" WidthRequest="46" />
                        <Button Grid.Column="6" BackgroundColor="#A855F7" BorderColor="#A855F7" Clicked="OnColorClicked" CommandParameter="Purple" HeightRequest="42" SemanticProperties.Description="Purple text" Text="" WidthRequest="46" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="LED preview" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding ColumnCount, StringFormat='{}{0} columns'}" Style="{StaticResource TinyLabelStyle}" />
                    </Grid>
                    <Border
                        Grid.Row="1"
                        BackgroundColor="#03050A"
                        Padding="8"
                        Stroke="{StaticResource AccentBlueColor}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <CollectionView
                            HeightRequest="168"
                            ItemsSource="{Binding PreviewCells}"
                            SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="48" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="text:TextPreviewCell">
                                    <BoxView
                                        Color="{Binding FillColor}"
                                        HeightRequest="8"
                                        HorizontalOptions="Center"
                                        WidthRequest="8" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding ActiveTransportText}" Style="{StaticResource MutedLabelStyle}" />
                            <Label Text="{Binding ProfileSummary}" TextColor="{StaticResource AccentYellowColor}" Style="{StaticResource TinyLabelStyle}" />
                            <Label Text="{Binding AcknowledgementModeText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <Label Text="Write-only" Style="{StaticResource TinyLabelStyle}" VerticalTextAlignment="Center" />
                            <Switch
                                IsEnabled="{Binding CanUseCompatibilityWriteOnly}"
                                IsToggled="{Binding UseCompatibilityWriteOnly, Mode=TwoWay}" />
                        </HorizontalStackLayout>
                    </Grid>
                    <Label Grid.Row="3" Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Text presets" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Text="{Binding PresetStatusText}" Style="{StaticResource TinyLabelStyle}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                            <Label Text="{Binding SavedPresetCards.Count, StringFormat='Saved {0}'}" Style="{StaticResource ChipLabelStyle}" />
                        </Border>
                    </Grid>

                    <Entry
                        Grid.Row="1"
                        Placeholder="Preset name"
                        Text="{Binding PresetName, Mode=TwoWay}" />

                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Picker
                            Title="Category"
                            ItemsSource="{Binding PresetCategoryOptions}"
                            SelectedItem="{Binding SelectedPresetCategory, Mode=TwoWay}" />
                        <Picker
                            Grid.Column="1"
                            Title="Send profile"
                            ItemsSource="{Binding PresetSendProfileOptions}"
                            SelectedItem="{Binding SelectedPresetSendProfile, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Switch IsToggled="{Binding IsFavorite, Mode=TwoWay}" />
                            <Label Text="Favorite" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Switch IsToggled="{Binding UseBlackBackgroundReset, Mode=TwoWay}" />
                            <Label Text="Black reset" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Spacing="8">
                            <Switch IsToggled="{Binding ShowInReact, Mode=TwoWay}" />
                            <Label Text="React" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                            <Switch IsToggled="{Binding ShowInRave, Mode=TwoWay}" />
                            <Label Text="RAVE" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Grid>

                    <HorizontalStackLayout Grid.Row="4" Spacing="8">
                        <Switch IsToggled="{Binding ShowInControl, Mode=TwoWay}" />
                        <Label Text="Show in Control favorites" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Grid.Row="5" Spacing="4">
                        <Label Text="{Binding MaskSafeTextWarning}" TextColor="{StaticResource AccentYellowColor}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Text="{Binding SelectedStyleSummary}" Style="{StaticResource TinyLabelStyle}" />
                    </VerticalStackLayout>

                    <Grid Grid.Row="6" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                        <Button Text="Save as Preset" Command="{Binding SaveAsPresetCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Save Changes" Command="{Binding SaveChangesCommand}" />
                        <Button Grid.Row="1" Text="Duplicate Loaded" Command="{Binding DuplicatePresetCommand}" />
                        <Button Grid.Row="1" Grid.Column="1" Text="Delete Loaded" Command="{Binding DeletePresetCommand}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <Label Text="Open a preset" Style="{StaticResource SectionTitleLabelStyle}" />
                    <CollectionView
                        Grid.Row="1"
                        HeightRequest="420"
                        ItemsSource="{Binding SavedPresetCards}"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="text:TextComposerPresetCard">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    BackgroundColor="#111827"
                                    Stroke="#24324A"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                                <Label Text="{Binding InputText}" Style="{StaticResource MutedLabelStyle}" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1" BackgroundColor="{Binding ColorHex}" HeightRequest="28" WidthRequest="28">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Label Text="{Binding CategoryText}" Style="{StaticResource TinyLabelStyle}" />
                                            <Label Grid.Column="1" Text="{Binding VisibilityText}" Style="{StaticResource TinyLabelStyle}" HorizontalTextAlignment="End" />
                                        </Grid>

                                        <VerticalStackLayout Grid.Row="2" Spacing="2">
                                            <Label Text="{Binding StyleSummary}" Style="{StaticResource TinyLabelStyle}" />
                                            <Label Text="{Binding LastSendStatusText}" Style="{StaticResource TinyLabelStyle}" />
                                            <Label Text="{Binding MaskTextWarning}" TextColor="{StaticResource AccentYellowColor}" Style="{StaticResource TinyLabelStyle}" IsVisible="{Binding HasMaskTextDifference}" />
                                        </VerticalStackLayout>

                                        <Grid Grid.Row="3" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                            <Button Text="Open" Command="{Binding OpenCommand}" />
                                            <Button Grid.Column="1" Text="Send" Command="{Binding SendCommand}" Style="{StaticResource NeonBlueButtonStyle}" />
                                            <Button Grid.Column="2" Text="Copy" Command="{Binding DuplicateCommand}" />
                                            <Button Grid.Column="3" Text="Del" Command="{Binding DeleteCommand}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Button x:Name="DiagnosticsToggle" Text="Show diagnostics" Clicked="OnToggleDiagnosticsClicked" Style="{StaticResource SecondaryButtonStyle}" />
            <Border x:Name="DiagnosticsPanel" IsVisible="False" Style="{StaticResource PanelBorderStyle}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Label Text="Diagnostics" Style="{StaticResource SectionTitleLabelStyle}" />
                    <Grid
                        Grid.Row="1"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="4">
                        <Label Text="Command" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding LastCommandText}" Style="{StaticResource MutedLabelStyle}" />

                        <Label Grid.Row="1" Text="Frames" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding FrameCount}" Style="{StaticResource MutedLabelStyle}" />

                        <Label Grid.Row="2" Text="Payload" Style="{StaticResource TinyLabelStyle}" />
                        <Label
                            Grid.Row="2"
                            Grid.Column="1"
                            FontSize="12"
                            LineBreakMode="CharacterWrap"
                            Text="{Binding LastPayloadHex}"
                            TextColor="{StaticResource SecondaryTextColor}" />
                    </Grid>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
