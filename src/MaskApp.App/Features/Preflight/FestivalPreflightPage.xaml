<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Preflight.FestivalPreflightPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:preflight="clr-namespace:MaskApp.Core.Features.Preflight;assembly=MaskApp.Core"
    x:DataType="preflight:FestivalPreflightViewModel"
    Title="Festival Preflight"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="Auto,*">
        <Grid Padding="18,14" ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Button Text="‹" Clicked="OnBackClicked" SemanticProperties.Description="Back to Pages" />
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="Festival Preflight" Style="{StaticResource PageTitleLabelStyle}" />
                <Label Text="Prove the selected show is ready for this physical mask." Style="{StaticResource TinyLabelStyle}" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,0,18,24" Spacing="18">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                    <Label
                        Text="{Binding StatusText}"
                        TextColor="{Binding StatusColorHex}"
                        FontSize="34"
                        FontAttributes="Bold"
                        SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1" Text="{Binding ScopeText}" FontSize="18" FontAttributes="Bold" />
                    <Label Grid.Row="2" Text="{Binding SummaryText}" Style="{StaticResource MutedLabelStyle}" />
                </Grid>

                <VerticalStackLayout Spacing="5">
                    <Label Text="MASK" Style="{StaticResource TinyLabelStyle}" TextColor="{StaticResource AccentBlueColor}" />
                    <Label Text="{Binding ActiveMaskText}" FontAttributes="Bold" />
                    <Label Text="{Binding LastRunText}" Style="{StaticResource TinyLabelStyle}" />
                </VerticalStackLayout>

                <BoxView Style="{StaticResource ListSeparatorStyle}" />

                <VerticalStackLayout Spacing="10">
                    <Label Text="SCOPE" FontAttributes="Bold" />
                    <Picker
                        Title="Choose a Page"
                        ItemsSource="{Binding Pages}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedPage}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Check Page" Command="{Binding RunSelectedPageCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Check whole show" Command="{Binding RunWholeShowCommand}" Style="{StaticResource BrightButtonStyle}" />
                    </Grid>
                    <Button
                        Text="{Binding ActiveSetlistText}"
                        Command="{Binding RunActiveSetlistCommand}"
                        IsEnabled="{Binding HasActiveSetlist}"
                        Style="{StaticResource BrightButtonStyle}" />
                    <Button
                        Text="Prepare eligible DIY content"
                        Command="{Binding PrepareDiyContentCommand}"
                        Style="{StaticResource NeonBlueButtonStyle}" />
                    <Label Text="{Binding PreparationStatusText}" Style="{StaticResource TinyLabelStyle}" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="FLASH SAFETY" FontAttributes="Bold" />
                    <Label Text="{Binding FlashSafetySummary}" Style="{StaticResource MutedLabelStyle}" />
                    <Button
                        Text="Review and acknowledge blocked revisions"
                        Clicked="OnAcknowledgeFlashRiskClicked"
                        IsVisible="{Binding HasBlockedFlashSafety}"
                        BackgroundColor="#7F1D1D"
                        TextColor="White"
                        SemanticProperties.Description="Review the photosensitivity warning and explicitly acknowledge each exact blocked animation revision" />
                    <Button
                        Text="Revoke flash-risk overrides"
                        Clicked="OnRevokeFlashRiskClicked"
                        IsVisible="{Binding HasAcknowledgedFlashSafety}"
                        Style="{StaticResource BrightButtonStyle}"
                        SemanticProperties.Description="Revoke flash-risk acknowledgements and block those animation revisions again" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="ISSUES AND RECOVERY" FontAttributes="Bold" />
                    <Label Text="No issues found." IsVisible="{Binding HasNoIssues}" Style="{StaticResource MutedLabelStyle}" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Issues}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="preflight:PreflightIssue">
                                <Grid Padding="0,12" RowDefinitions="Auto,Auto,Auto,1" ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="4">
                                    <Label Text="{Binding SeverityText}" TextColor="{Binding ColorHex}" FontAttributes="Bold" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding Message}" FontAttributes="Bold" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding RecoveryAction}" Style="{StaticResource MutedLabelStyle}" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding Code}" Style="{StaticResource TinyLabelStyle}" />
                                    <BoxView Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource ListSeparatorStyle}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="ACTION READINESS" FontAttributes="Bold" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Actions}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="preflight:PreflightActionAssessment">
                                <Grid Padding="0,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,1" RowSpacing="3">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="{Binding ClassificationText}" TextColor="{Binding ColorHex}" FontAttributes="Bold" FontSize="12" />
                                    <Label Grid.Row="1" Text="{Binding PageTitle, StringFormat='Page: {0}'}" Style="{StaticResource TinyLabelStyle}" />
                                    <BoxView Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource ListSeparatorStyle}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
