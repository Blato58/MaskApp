<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Device.DevicePickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    xmlns:connect="clr-namespace:MaskApp.Core.Features.Connect;assembly=MaskApp.Core"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="connect:ConnectViewModel"
    Title="{x:Static loc:AppText.ChooseMask}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <VerticalStackLayout Spacing="2">
            <Label Text="{x:Static loc:AppText.ChooseMask}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="{loc:Translate BluetoothPickerDetail}" Style="{StaticResource MutedLabelStyle}" />
        </VerticalStackLayout>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Button Text="{loc:Translate ScanForMasks}" Command="{Binding StartScanCommand}" IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Text="{loc:Translate StopScanning}" Command="{Binding StopScanCommand}" IsVisible="{Binding IsScanning}" />
            <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsScanning}" IsVisible="{Binding IsScanning}" />
        </Grid>
        <CollectionView Grid.Row="2" ItemsSource="{Binding DeviceRows}" SelectedItem="{Binding SelectedDeviceRow, Mode=TwoWay}" SelectionMode="Single">
            <CollectionView.EmptyView>
                <controls:EmptyStateView Title="{loc:Translate NoNearbyMasks}" Message="{loc:Translate NoNearbyMasksDetail}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="connect:DevicePickerRow">
                    <Grid Padding="12" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" MinimumHeightRequest="72">
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="17" />
                            <Label Text="{loc:Translate RecognizedNearbyMask}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="{Binding SignalStrength, StringFormat='{}{0} dBm'}" VerticalTextAlignment="Center" />
                        <Grid Grid.Row="1" Grid.ColumnSpan="2" IsVisible="{Binding IsRetryTarget}" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Label Text="{Binding ErrorText}" TextColor="{AppThemeBinding Dark={StaticResource DarkDangerColor}, Light={StaticResource LightDangerColor}}" />
                            <Button Grid.Row="1" Text="{loc:Translate RetryThisMask}" Command="{Binding ConnectCommand, Source={RelativeSource AncestorType={x:Type connect:ConnectViewModel}}, x:DataType=connect:ConnectViewModel}" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Label Text="{Binding StatusText}" Style="{StaticResource MutedLabelStyle}" MaxLines="3" />
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="{loc:Translate ContinueOffline}" Clicked="OnCloseClicked" />
                <Button Grid.Column="1" Text="{loc:Translate ConnectSelected}" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
            <Button Grid.Row="2" Text="{loc:Translate OpenSettings}" Clicked="OnOpenSettingsClicked" MinimumHeightRequest="48" />
        </Grid>
    </Grid>
</ContentPage>
