<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Shows.SceneEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:scenes="clr-namespace:MaskApp.Core.Features.Scenes;assembly=MaskApp.Core"
    xmlns:loc="clr-namespace:MaskApp.App.Resources.Strings"
    x:DataType="scenes:SceneStudioViewModel"
    Title="{x:Static loc:AppText.SceneEditor}"
    BackgroundColor="{AppThemeBinding Dark={StaticResource DarkCanvasColor}, Light={StaticResource LightCanvasColor}}">
    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="2">
            <Label Text="{x:Static loc:AppText.SceneEditor}" Style="{StaticResource PageTitleLabelStyle}" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="{loc:Translate SceneBoundsDetail}" Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="{loc:Translate NewScene}" Command="{Binding NewSceneCommand}" MinimumHeightRequest="48" />
        </Grid>
        <Entry Grid.Row="1" Placeholder="{loc:Translate SceneName}" Text="{Binding SceneName, Mode=TwoWay}" MinimumHeightRequest="48" />
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label Text="{loc:Translate OnFailure}" VerticalTextAlignment="Center" />
            <Picker Grid.Column="1" ItemsSource="{Binding FailurePolicies}" SelectedItem="{Binding FailurePolicy, Mode=TwoWay}" MinimumHeightRequest="48" />
        </Grid>
        <CollectionView Grid.Row="3" ItemsSource="{Binding StepRows}" SelectionMode="Single" SelectionChanged="OnStepSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="scenes:SceneStepRow">
                    <Grid Padding="0,10" RowDefinitions="Auto,Auto" ColumnDefinitions="48,*" ColumnSpacing="8" RowSpacing="8" MinimumHeightRequest="112">
                        <Label Text="{Binding DisplayIndex}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Summary}" Style="{StaticResource MutedLabelStyle}" MaxLines="2" />
                        </VerticalStackLayout>
                        <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,2*" ColumnSpacing="8">
                            <Button Text="↑" Clicked="OnMoveStepEarlier" MinimumHeightRequest="48" SemanticProperties.Description="{loc:Translate MoveEarlier}" />
                            <Button Grid.Column="1" Text="↓" Clicked="OnMoveStepLater" MinimumHeightRequest="48" SemanticProperties.Description="{loc:Translate MoveLater}" />
                            <Button Grid.Column="2" Text="{loc:Translate Remove}" Clicked="OnRemoveStep" Style="{StaticResource DangerButtonStyle}" MinimumHeightRequest="48" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Picker ItemsSource="{Binding StepKinds}" SelectedItem="{Binding NewStepKind, Mode=TwoWay}" MinimumHeightRequest="48" />
            <Picker Grid.Column="1" ItemsSource="{Binding ContentOptions}" ItemDisplayBinding="{Binding Title}" SelectedItem="{Binding SelectedContentItem, Mode=TwoWay}" IsVisible="{Binding NeedsContentItem}" MinimumHeightRequest="48" />
            <Button Grid.Column="2" Text="{x:Static loc:AppText.AddStep}" Clicked="OnAddStep" MinimumHeightRequest="48" />
        </Grid>
        <Grid Grid.Row="5" RowDefinitions="Auto,Auto" RowSpacing="8">
            <Label Text="{Binding ValidationSummary}" Style="{StaticResource MutedLabelStyle}" />
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Text="{x:Static loc:AppText.Save}" Command="{Binding SaveSceneCommand}" />
                <Button Grid.Column="1" Text="{loc:Translate Rehearse}" Command="{Binding RehearseSceneCommand}" />
                <Button Grid.Column="2" Text="{x:Static loc:AppText.Blackout}" Command="{Binding BlackoutCommand}" Style="{StaticResource DangerButtonStyle}" />
            </Grid>
        </Grid>
        <Border Grid.Row="6" Style="{StaticResource PanelBorderStyle}" IsVisible="{Binding IsSceneValid, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{loc:Translate BrokenReferences}" Style="{StaticResource SectionTitleLabelStyle}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ValidationIssues}" Spacing="4">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="scenes:SceneValidationIssue">
                            <Label Text="{Binding Message}" TextColor="{AppThemeBinding Dark={StaticResource DarkDangerColor}, Light={StaticResource LightDangerColor}}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
                <Label Text="{loc:Translate BrokenReferencesDetail}" Style="{StaticResource MutedLabelStyle}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="{loc:Translate ReplaceSelected}" Clicked="OnReplaceStep" />
                    <Button Grid.Column="1" Text="{loc:Translate RemoveSelected}" Clicked="OnRemoveStep" Style="{StaticResource DangerButtonStyle}" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
