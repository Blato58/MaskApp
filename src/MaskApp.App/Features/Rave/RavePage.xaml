<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MaskApp.App.Features.Rave.RavePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:builtins="clr-namespace:MaskApp.Core.Features.BuiltIns;assembly=MaskApp.Core"
    xmlns:presets="clr-namespace:MaskApp.Core.Features.TextPresets;assembly=MaskApp.Core"
    xmlns:rave="clr-namespace:MaskApp.Core.Features.Rave;assembly=MaskApp.Core"
    x:DataType="rave:RaveViewModel"
    Title="RAVE"
    BackgroundColor="{StaticResource PageBackgroundColor}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="16">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="RAVE Mode" Style="{StaticResource PageTitleLabelStyle}" />
                                <Label Text="{Binding ConnectionStatusText}" Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                            <ActivityIndicator
                                Grid.Column="1"
                                IsRunning="{Binding IsSending}"
                                IsVisible="{Binding IsSending}"
                                VerticalOptions="Center" />
                        </Grid>
                        <Label Grid.Row="1" Text="{Binding QuickCaptionProfileText}" TextColor="{StaticResource AccentYellowColor}" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="2" Text="{Binding AutoConnectStatusText}" Style="{StaticResource TinyLabelStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Live controls" Style="{StaticResource SectionTitleLabelStyle}" />
                                <Label Text="{Binding ControlsStatusText}" Style="{StaticResource TinyLabelStyle}" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="1"
                                Text="Connect"
                                Clicked="OnConnectClicked"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <Button
                                HeightRequest="72"
                                Text="BLACKOUT"
                                Command="{Binding BlackoutCommand}"
                                Style="{StaticResource DangerButtonStyle}" />
                            <Button
                                Grid.Column="1"
                                HeightRequest="72"
                                Text="Text Composer"
                                Clicked="OnOpenTextClicked"
                                Style="{StaticResource NeonBlueButtonStyle}" />
                            <Button
                                Grid.Row="1"
                                HeightRequest="56"
                                Text="Apply cap"
                                Command="{Binding ApplyBrightnessCapCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                HeightRequest="56"
                                Text="Restore"
                                Command="{Binding RestoreCommand}" />
                        </Grid>
                    </Grid>
                </Border>

                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding PresetGroups}"
                    Spacing="14">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="presets:TextPresetGroup">
                            <Border Style="{StaticResource PanelBorderStyle}">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" Style="{StaticResource SectionTitleLabelStyle}" />
                                        <Border Grid.Column="1" Style="{StaticResource StatusPillBorderStyle}">
                                            <Label Text="{Binding Cards.Count, StringFormat='{}{0} presets'}" Style="{StaticResource ChipLabelStyle}" />
                                        </Border>
                                    </Grid>
                                    <FlexLayout
                                        Grid.Row="1"
                                        AlignItems="Stretch"
                                        BindableLayout.ItemsSource="{Binding Cards}"
                                        Direction="Row"
                                        Wrap="Wrap">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="presets:TextPresetCard">
                                                <Border
                                                    Margin="0,0,10,10"
                                                    MinimumHeightRequest="96"
                                                    MinimumWidthRequest="154"
                                                    Style="{StaticResource ActionCardBorderStyle}"
                                                    Stroke="{Binding ColorHex}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding SendCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <BoxView Color="{Binding ColorHex}" HeightRequest="18" WidthRequest="18" VerticalOptions="Center" />
                                                            <Label Grid.Column="1" Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="18" LineBreakMode="TailTruncation" />
                                                        </Grid>
                                                        <Label Grid.Row="1" Text="{Binding InputText}" TextColor="{Binding ColorHex}" FontAttributes="Bold" FontSize="16" />
                                                        <Label Grid.Row="2" Text="{Binding MaskTextWarning}" IsVisible="{Binding HasMaskTextDifference}" Style="{StaticResource TinyLabelStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Label Text="DnB deck" Style="{StaticResource SectionTitleLabelStyle}" />
                        <FlexLayout
                            Grid.Row="1"
                            AlignItems="Stretch"
                            BindableLayout.ItemsSource="{Binding Actions}"
                            Direction="Row"
                            JustifyContent="SpaceBetween"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="rave:RaveAction">
                                    <Border
                                        Margin="0,0,10,10"
                                        MinimumHeightRequest="86"
                                        MinimumWidthRequest="150"
                                        Style="{StaticResource ActionCardBorderStyle}"
                                        Stroke="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SendCommand}" />
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Label
                                                    Text="{Binding Id, Converter={StaticResource QuickActionIconConverter}}"
                                                    TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                    FontAttributes="Bold"
                                                    VerticalTextAlignment="Center" />
                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding Label}"
                                                    FontAttributes="Bold"
                                                    FontSize="18"
                                                    LineBreakMode="TailTruncation" />
                                            </Grid>
                                            <Label
                                                Grid.Row="1"
                                                Text="{Binding Caption}"
                                                TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                VerticalTextAlignment="Center" />
                                            <Label Grid.Row="2" Text="{Binding Group}" Style="{StaticResource TinyLabelStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                        <Label Text="Favorite Faces" Style="{StaticResource SectionTitleLabelStyle}" />
                        <Label Grid.Row="1" Text="{Binding FavoriteBuiltInsHintText}" Style="{StaticResource MutedLabelStyle}" />
                        <FlexLayout
                            Grid.Row="2"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding FavoriteBuiltIns}"
                            Direction="Row"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="builtins:BuiltInAssetAction">
                                    <Border
                                        Margin="0,0,10,10"
                                        MinimumWidthRequest="148"
                                        Style="{StaticResource ActionCardBorderStyle}"
                                        Stroke="{StaticResource AccentBlueColor}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SendCommand}" />
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                                            <Label Text="{Binding Label}" FontAttributes="Bold" TextColor="{StaticResource AccentBlueColor}" />
                                            <Label Grid.Row="1" Text="{Binding Caption}" Style="{StaticResource TinyLabelStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Label Grid.Row="3" Text="Fallbacks" Style="{StaticResource SectionTitleLabelStyle}" />
                        <FlexLayout
                            Grid.Row="4"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding CommandFallbackActions}"
                            Direction="Row"
                            Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="rave:RaveAction">
                                    <Button
                                        Margin="0,0,10,10"
                                        MinimumWidthRequest="132"
                                        HeightRequest="52"
                                        Text="{Binding Label}"
                                        Command="{Binding SendCommand}"
                                        BorderColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                        TextColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}}"
                                        BackgroundColor="{Binding Id, Converter={StaticResource QuickActionAccentColorConverter}, ConverterParameter=soft}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Text="Brightness cap" Style="{StaticResource SectionTitleLabelStyle}" />
                            <Label Grid.Column="1" Text="{Binding BrightnessCap, StringFormat='{}{0}%'}" Style="{StaticResource MetricLabelStyle}" />
                        </Grid>
                        <Slider
                            Grid.Row="1"
                            Minimum="1"
                            Maximum="100"
                            Value="{Binding BrightnessCap, Mode=TwoWay}" />
                        <Label Grid.Row="2" Text="Keep the cap reachable for dark-room recovery without hiding other controls." Style="{StaticResource TinyLabelStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CompactPanelBorderStyle}">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="4">
                        <Label Text="Send" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Column="1" Text="{Binding SendStatusText}" />
                        <Label Grid.Row="1" Text="Transport" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding ActiveTransportText}" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="2" Text="Action" Style="{StaticResource TinyLabelStyle}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding LastActionText}" />
                        <Label Grid.Row="3" Text="Payload" Style="{StaticResource TinyLabelStyle}" />
                        <Label
                            Grid.Row="3"
                            Grid.Column="1"
                            FontSize="12"
                            LineBreakMode="CharacterWrap"
                            Text="{Binding LastPayloadText}"
                            TextColor="{StaticResource SecondaryTextColor}" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid
            Grid.Row="1"
            Padding="14"
            BackgroundColor="{StaticResource SurfaceColor}"
            ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="10">
            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                <Label Text="BLACKOUT always available" FontAttributes="Bold" />
                <Label Text="{Binding SendStatusText}" Style="{StaticResource TinyLabelStyle}" />
            </VerticalStackLayout>
            <Button
                Grid.Column="1"
                HeightRequest="56"
                Text="Text"
                Clicked="OnOpenTextClicked"
                Style="{StaticResource NeonBlueButtonStyle}" />
            <Button
                Grid.Column="2"
                HeightRequest="56"
                Text="Connect"
                Clicked="OnConnectClicked"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                Grid.Column="3"
                HeightRequest="56"
                Text="BLACKOUT"
                Command="{Binding BlackoutCommand}"
                Style="{StaticResource DangerButtonStyle}" />
        </Grid>
    </Grid>
</ContentPage>
