<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.OperationalStatusBadge"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:OperationalStatusBadge"
    x:Name="Root">
    <Border
        Padding="8,4"
        BackgroundColor="Transparent"
        Stroke="{Binding AccentColor, Source={x:Reference Root}}"
        StrokeThickness="1"
        SemanticProperties.Description="{Binding Text, Source={x:Reference Root}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="10" />
        </Border.StrokeShape>
        <HorizontalStackLayout Spacing="5">
            <Label
                Text="{Binding Icon, Source={x:Reference Root}}"
                TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                FontSize="11"
                FontAttributes="Bold" />
            <Label
                Text="{Binding Text, Source={x:Reference Root}}"
                TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="0.4" />
        </HorizontalStackLayout>
    </Border>
</ContentView>
