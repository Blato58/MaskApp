<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.ConnectionPill"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:ConnectionPill"
    x:Name="Root">
    <Border
        Padding="12,6"
        Stroke="{Binding AccentColor, Source={x:Reference Root}}"
        StrokeThickness="1"
        BackgroundColor="Transparent"
        MinimumHeightRequest="40"
        SemanticProperties.Description="{Binding SemanticDescription, Source={x:Reference Root}}">
        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
            <Label Text="{Binding Icon, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontAttributes="Bold" />
            <Label Text="{Binding Text, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontSize="14" FontAttributes="Bold" />
        </HorizontalStackLayout>
    </Border>
</ContentView>
