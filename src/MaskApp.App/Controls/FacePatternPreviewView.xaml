<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.FacePatternPreviewView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:FacePatternPreviewView"
    x:Name="Root">
    <Border
        BackgroundColor="#09090B"
        Padding="6"
        Stroke="{StaticResource SeparatorColor}"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="10" />
        </Border.StrokeShape>
        <GraphicsView
            x:Name="PreviewCanvas"
            SemanticProperties.Description="{Binding SemanticDescription, Source={x:Reference Root}}" />
    </Border>
</ContentView>
