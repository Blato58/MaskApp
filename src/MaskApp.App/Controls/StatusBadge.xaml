<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.StatusBadge"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
    <Border Padding="9,5" Stroke="{Binding AccentColor, Source={x:Reference Root}}" StrokeThickness="1" BackgroundColor="Transparent">
        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
        <HorizontalStackLayout Spacing="6">
            <Label Text="{Binding Icon, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" />
            <Label Text="{Binding Text, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontSize="12" FontAttributes="Bold" />
        </HorizontalStackLayout>
    </Border>
</ContentView>
