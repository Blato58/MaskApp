<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.DeliveryStatus"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:DeliveryStatus"
    x:Name="Root">
    <Border Padding="12,9" Stroke="{Binding AccentColor, Source={x:Reference Root}}" StrokeThickness="1" BackgroundColor="Transparent">
        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label Text="{Binding Icon, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontSize="18" VerticalTextAlignment="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="1">
                <Label Text="{Binding Label, Source={x:Reference Root}}" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontAttributes="Bold" />
                <Label Text="{Binding Detail, Source={x:Reference Root}}" Style="{StaticResource TinyLabelStyle}" MaxLines="2" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
