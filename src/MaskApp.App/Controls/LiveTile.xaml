<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.LiveTile"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:LiveTile"
    x:Name="Root">
    <Border
        Padding="12"
        MinimumHeightRequest="148"
        BackgroundColor="{AppThemeBinding Dark={StaticResource DarkSurfaceColor}, Light={StaticResource LightSurfaceColor}}"
        Stroke="{Binding Item.ColorHex, Source={x:Reference Root}}"
        StrokeThickness="1">
        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
        <Grid RowDefinitions="80,Auto,Auto" RowSpacing="5">
            <Border
                HeightRequest="76"
                WidthRequest="76"
                HorizontalOptions="Center"
                BackgroundColor="{Binding Item.ColorHex, Source={x:Reference Root}}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Grid Padding="6">
                    <Image
                        Source="{Binding Item.IconAsset, Source={x:Reference Root}}"
                        HeightRequest="36"
                        WidthRequest="36"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding Item.HasAnyPreview, Source={x:Reference Root}, Converter={StaticResource InvertedBoolConverter}}" />
                    <controls:BuiltInPreviewView
                        Source="{Binding Item.PreviewResourceName, Source={x:Reference Root}}"
                        IsAnimationPlaying="{Binding Item.IsAnimationPlaying, Source={x:Reference Root}}"
                        IsVisible="{Binding Item.HasPreview, Source={x:Reference Root}}" />
                    <controls:FacePatternPreviewView
                        Pattern="{Binding Item.FacePattern, Source={x:Reference Root}}"
                        IsVisible="{Binding Item.HasFacePreview, Source={x:Reference Root}}" />
                </Grid>
            </Border>
            <Label
                Grid.Row="1"
                Text="{Binding Item.Label, Source={x:Reference Root}}"
                FontAttributes="Bold"
                FontSize="16"
                HorizontalTextAlignment="Center"
                MaxLines="2"
                LineBreakMode="TailTruncation" />
            <Label
                Grid.Row="2"
                Text="{Binding InteractionHint, Source={x:Reference Root}}"
                Style="{StaticResource TinyLabelStyle}"
                HorizontalTextAlignment="Center"
                MaxLines="1" />
            <Button
                Grid.RowSpan="3"
                Text=""
                BackgroundColor="Transparent"
                BorderWidth="0"
                Pressed="OnPressed"
                Released="OnReleased"
                Clicked="OnClicked"
                SemanticProperties.Description="{Binding Item.Label, Source={x:Reference Root}}"
                SemanticProperties.Hint="{Binding InteractionHint, Source={x:Reference Root}}" />
        </Grid>
    </Border>
</ContentView>
