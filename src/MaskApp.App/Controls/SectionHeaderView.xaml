<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.SectionHeaderView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:SectionHeaderView"
    x:Name="Root">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <VerticalStackLayout Spacing="2">
            <Label
                Text="{Binding Title, Source={x:Reference Root}}"
                Style="{StaticResource SectionTitleLabelStyle}"
                SemanticProperties.HeadingLevel="Level2" />
            <Label
                Text="{Binding Subtitle, Source={x:Reference Root}}"
                IsVisible="{Binding HasSubtitle, Source={x:Reference Root}}"
                Style="{StaticResource TinyLabelStyle}"
                MaxLines="2" />
        </VerticalStackLayout>
        <Button
            Grid.Column="1"
            Text="{Binding ActionText, Source={x:Reference Root}}"
            Command="{Binding ActionCommand, Source={x:Reference Root}}"
            IsVisible="{Binding ShowAction, Source={x:Reference Root}}"
            Style="{StaticResource QuietButtonStyle}" />
    </Grid>
</ContentView>
