<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MaskApp.App.Controls.InlineIssue" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Name="Root">
    <Border Padding="12" Stroke="{Binding AccentColor, Source={x:Reference Root}}" StrokeThickness="1" BackgroundColor="Transparent">
        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Label Text="!" TextColor="{Binding AccentColor, Source={x:Reference Root}}" FontAttributes="Bold" />
            <VerticalStackLayout Grid.Column="1" Spacing="2"><Label Text="{Binding Title, Source={x:Reference Root}}" FontAttributes="Bold" /><Label Text="{Binding Message, Source={x:Reference Root}}" Style="{StaticResource TinyLabelStyle}" /></VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
