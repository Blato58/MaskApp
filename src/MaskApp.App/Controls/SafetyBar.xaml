<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.SafetyBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:SafetyBar"
    x:Name="Root">
    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="0,8">
        <Button
            Text="{Binding StopText, Source={x:Reference Root}}"
            Command="{Binding StopCommand, Source={x:Reference Root}}"
            IsEnabled="{Binding IsTransportAvailable, Source={x:Reference Root}}"
            MinimumHeightRequest="{Binding MinimumTargetHeight, Source={x:Reference Root}}"
            SemanticProperties.Hint="Stops app-timed playback without sending Blackout" />
        <Button
            Grid.Column="1"
            Text="{Binding BlackoutText, Source={x:Reference Root}}"
            Command="{Binding BlackoutCommand, Source={x:Reference Root}}"
            IsEnabled="{Binding IsTransportAvailable, Source={x:Reference Root}}"
            MinimumHeightRequest="{Binding MinimumTargetHeight, Source={x:Reference Root}}"
            BackgroundColor="{StaticResource DarkDangerFillColor}"
            BorderColor="{StaticResource DarkDangerColor}"
            TextColor="White"
            SemanticProperties.Hint="Immediately requests emergency Blackout when transport is available" />
    </Grid>
</ContentView>
