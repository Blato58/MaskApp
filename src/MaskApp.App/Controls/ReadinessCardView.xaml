<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MaskApp.App.Controls.ReadinessCardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MaskApp.App.Controls"
    x:DataType="controls:ReadinessCardView"
    x:Name="Root">
    <Border
        Style="{StaticResource ReadinessCardBorderStyle}"
        Stroke="{Binding AccentColor, Source={x:Reference Root}}"
        SemanticProperties.Description="{Binding StatusText, Source={x:Reference Root}}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
            <Label
                Text="{Binding Icon, Source={x:Reference Root}}"
                TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                FontSize="38"
                FontAttributes="Bold"
                VerticalTextAlignment="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                <Label
                    Text="{Binding StatusText, Source={x:Reference Root}}"
                    TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                    FontSize="26"
                    FontAttributes="Bold"
                    CharacterSpacing="0.5" />
                <Label
                    Text="{Binding Summary, Source={x:Reference Root}}"
                    Style="{StaticResource MutedLabelStyle}"
                    MaxLines="3" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
