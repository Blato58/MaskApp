<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="MaskApp.App.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:visuals="clr-namespace:MaskApp.App.Infrastructure.Visuals">
    <Application.Resources>
        <ResourceDictionary>
            <visuals:QuickActionAccentColorConverter x:Key="QuickActionAccentColorConverter" />
            <visuals:QuickActionIconConverter x:Key="QuickActionIconConverter" />
            <visuals:TransportStateColorConverter x:Key="TransportStateColorConverter" />
            <visuals:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <!-- Semantic palette. Rebuilt screens consume these through AppThemeBinding. -->
            <Color x:Key="DarkCanvasColor">#07080B</Color>
            <Color x:Key="DarkSurfaceColor">#111319</Color>
            <Color x:Key="DarkRaisedColor">#181B23</Color>
            <Color x:Key="DarkBorderColor">#343A46</Color>
            <Color x:Key="DarkPrimaryTextColor">#F7F8FA</Color>
            <Color x:Key="DarkSecondaryTextColor">#A7ADBA</Color>
            <Color x:Key="DarkActionColor">#7C3AED</Color>
            <Color x:Key="DarkAccentColor">#8B5CF6</Color>
            <Color x:Key="DarkConnectionColor">#22D3EE</Color>
            <Color x:Key="DarkSuccessColor">#34D399</Color>
            <Color x:Key="DarkWarningColor">#FBBF24</Color>
            <Color x:Key="DarkDangerColor">#F43F5E</Color>
            <Color x:Key="DarkDangerFillColor">#BE123C</Color>
            <Color x:Key="DarkFocusColor">#A78BFA</Color>

            <Color x:Key="LightCanvasColor">#F7F8FB</Color>
            <Color x:Key="LightSurfaceColor">#FFFFFF</Color>
            <Color x:Key="LightRaisedColor">#F0F2F6</Color>
            <Color x:Key="LightBorderColor">#D8DDE6</Color>
            <Color x:Key="LightPrimaryTextColor">#16181D</Color>
            <Color x:Key="LightSecondaryTextColor">#5B6270</Color>
            <Color x:Key="LightActionColor">#6D28D9</Color>
            <Color x:Key="LightAccentColor">#7C3AED</Color>
            <Color x:Key="LightConnectionColor">#087F8C</Color>
            <Color x:Key="LightSuccessColor">#087A55</Color>
            <Color x:Key="LightWarningColor">#8A5A00</Color>
            <Color x:Key="LightDangerColor">#BE123C</Color>
            <Color x:Key="LightDangerFillColor">#BE123C</Color>
            <Color x:Key="LightFocusColor">#6D28D9</Color>

            <!-- Dark fallbacks keep not-yet-rebuilt screens stable during the migration. -->
            <Color x:Key="PageBackgroundColor">#07080B</Color>
            <Color x:Key="SurfaceColor">#111319</Color>
            <Color x:Key="PanelColor">#111319</Color>
            <Color x:Key="PanelRaisedColor">#181B23</Color>
            <Color x:Key="PanelBorderColor">#343A46</Color>
            <Color x:Key="SeparatorColor">#343A46</Color>
            <Color x:Key="SelectedSurfaceColor">#2A1B4D</Color>
            <Color x:Key="OverlayScrimColor">#B3000000</Color>
            <Color x:Key="PrimaryTextColor">#F7F8FA</Color>
            <Color x:Key="SecondaryTextColor">#A7ADBA</Color>
            <Color x:Key="MutedTextColor">#A7ADBA</Color>
            <Color x:Key="AccentColor">#8B5CF6</Color>
            <Color x:Key="AccentBlueColor">#8B5CF6</Color>
            <Color x:Key="ConnectedColor">#22D3EE</Color>
            <Color x:Key="VerifiedColor">#34D399</Color>
            <Color x:Key="WarningColor">#FBBF24</Color>
            <Color x:Key="DangerColor">#F43F5E</Color>
            <Color x:Key="AccentGreenColor">#22C55E</Color>
            <Color x:Key="AccentYellowColor">#F59E0B</Color>
            <Color x:Key="AccentPinkColor">#EC4899</Color>
            <Color x:Key="ChipBackgroundColor">#202126</Color>
            <Color x:Key="InputBackgroundColor">#1D1E22</Color>
            <Color x:Key="DisabledActionColor">#475569</Color>
            <Thickness x:Key="PagePadding">16,16</Thickness>
            <Thickness x:Key="PageHorizontalPadding">16,0</Thickness>
            <x:Double x:Key="Space0">4</x:Double>
            <x:Double x:Key="Space1">8</x:Double>
            <x:Double x:Key="Space1Half">12</x:Double>
            <x:Double x:Key="Space2">16</x:Double>
            <x:Double x:Key="Space3">24</x:Double>
            <x:Double x:Key="Space4">32</x:Double>
            <x:Double x:Key="Space5">40</x:Double>
            <x:Double x:Key="Space6">48</x:Double>
            <x:Double x:Key="Space7">64</x:Double>
            <x:Double x:Key="ControlMinimumHeight">48</x:Double>
            <x:Double x:Key="StageControlMinimumHeight">72</x:Double>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryTextColor}, Dark={StaticResource DarkPrimaryTextColor}}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="PageTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryTextColor}, Dark={StaticResource DarkPrimaryTextColor}}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="ModeTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryTextColor}, Dark={StaticResource DarkPrimaryTextColor}}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="SectionTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightPrimaryTextColor}, Dark={StaticResource DarkPrimaryTextColor}}" />
                <Setter Property="CharacterSpacing" Value="1.1" />
            </Style>
            <Style x:Key="MutedLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightSecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="TinyLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightSecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="MetricLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightConnectionColor}, Dark={StaticResource DarkConnectionColor}}" />
            </Style>
            <Style x:Key="ChipLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightAccentColor}, Dark={StaticResource DarkAccentColor}}" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
            </Style>
            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurfaceColor}, Dark={StaticResource DarkSurfaceColor}}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightBorderColor}, Dark={StaticResource DarkBorderColor}}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="ContentCardBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="MinimumHeightRequest" Value="224" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="16" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="QuickDeckCardBorderStyle" TargetType="Border" BasedOn="{StaticResource ContentCardBorderStyle}">
                <Setter Property="MinimumHeightRequest" Value="164" />
                <Setter Property="WidthRequest" Value="136" />
                <Setter Property="Padding" Value="10" />
            </Style>
            <Style x:Key="ReadinessCardBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="18" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="16" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="MetricTileBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="MinimumHeightRequest" Value="104" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PerformanceTileBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="16" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="FrameThumbnailBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="6" />
                <Setter Property="BackgroundColor" Value="{StaticResource PanelColor}" />
                <Setter Property="Stroke" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="12" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="CompactPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
            </Style>
            <Style x:Key="ActionCardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Padding" Value="12,14" />
                <Setter Property="Stroke" Value="{StaticResource SeparatorColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="0" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="ListRowBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Padding" Value="4,14" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
            </Style>
            <Style x:Key="ListSeparatorStyle" TargetType="BoxView">
                <Setter Property="BackgroundColor" Value="{StaticResource SeparatorColor}" />
                <Setter Property="HeightRequest" Value="1" />
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="Margin" Value="76,0,0,0" />
            </Style>
            <Style x:Key="FullWidthListSeparatorStyle" TargetType="BoxView" BasedOn="{StaticResource ListSeparatorStyle}">
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style x:Key="StatusPillBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ChipBackgroundColor}" />
                <Setter Property="Padding" Value="9,4" />
                <Setter Property="Stroke" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="MinimumHeightRequest" Value="44" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="11" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="BackgroundColor" Value="{StaticResource PanelRaisedColor}" />
                <Setter Property="BorderColor" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
                <Setter Property="MinimumHeightRequest" Value="48" />
            </Style>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelRaisedColor}" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>
            <Style x:Key="CompactButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinimumHeightRequest" Value="48" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <Style x:Key="ModeButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinimumHeightRequest" Value="44" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource AccentColor}" />
            </Style>
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}" />
                <Setter Property="BorderColor" Value="#A78BFA" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="#FFFFFF" />
            </Style>
            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#2A1012" />
                <Setter Property="BorderColor" Value="{StaticResource DangerColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource DangerColor}" />
            </Style>
            <Style x:Key="BrightButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#10261A" />
                <Setter Property="BorderColor" Value="{StaticResource VerifiedColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource VerifiedColor}" />
            </Style>
            <Style x:Key="NeonBlueButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#092329" />
                <Setter Property="BorderColor" Value="{StaticResource ConnectedColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource ConnectedColor}" />
            </Style>
            <Style x:Key="EmergencyButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
                <Setter Property="BorderColor" Value="#FF7A7A" />
                <Setter Property="TextColor" Value="#050506" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="MinimumHeightRequest" Value="{StaticResource StageControlMinimumHeight}" />
            </Style>
            <Style x:Key="EditorToolButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinimumHeightRequest" Value="56" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
                <Setter Property="MinimumHeightRequest" Value="48" />
            </Style>
            <Style TargetType="SearchBar">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
                <Setter Property="CancelButtonColor" Value="{StaticResource AccentBlueColor}" />
                <Setter Property="MinimumHeightRequest" Value="48" />
            </Style>
            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="TitleColor" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="MinimumHeightRequest" Value="48" />
            </Style>
            <Style TargetType="ActivityIndicator">
                <Setter Property="Color" Value="{StaticResource ConnectedColor}" />
            </Style>
            <Style TargetType="Slider">
                <Setter Property="ThumbColor" Value="{StaticResource AccentColor}" />
                <Setter Property="MinimumTrackColor" Value="{StaticResource AccentColor}" />
                <Setter Property="MaximumTrackColor" Value="{StaticResource PanelBorderColor}" />
            </Style>
            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="{StaticResource AccentColor}" />
                <Setter Property="ThumbColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
