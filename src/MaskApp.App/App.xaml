<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="MaskApp.App.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:visuals="clr-namespace:MaskApp.App.Infrastructure.Visuals">
    <Application.Resources>
        <ResourceDictionary>
            <visuals:QuickActionAccentColorConverter x:Key="QuickActionAccentColorConverter" />
            <visuals:QuickActionIconConverter x:Key="QuickActionIconConverter" />
            <visuals:TransportStateColorConverter x:Key="TransportStateColorConverter" />

            <Color x:Key="PageBackgroundColor">#05070D</Color>
            <Color x:Key="SurfaceColor">#0B0F18</Color>
            <Color x:Key="PanelColor">#101622</Color>
            <Color x:Key="PanelRaisedColor">#151C2A</Color>
            <Color x:Key="PanelBorderColor">#263246</Color>
            <Color x:Key="PrimaryTextColor">#F8FAFC</Color>
            <Color x:Key="SecondaryTextColor">#A9B3C6</Color>
            <Color x:Key="MutedTextColor">#64748B</Color>
            <Color x:Key="AccentColor">#A78BFA</Color>
            <Color x:Key="AccentBlueColor">#52E3FF</Color>
            <Color x:Key="AccentGreenColor">#22C55E</Color>
            <Color x:Key="AccentYellowColor">#FACC15</Color>
            <Color x:Key="AccentPinkColor">#FF3D8B</Color>
            <Color x:Key="DangerColor">#FF5C54</Color>
            <Color x:Key="ChipBackgroundColor">#171E2C</Color>
            <Color x:Key="InputBackgroundColor">#0A0E16</Color>
            <Color x:Key="DisabledActionColor">#475569</Color>
            <Thickness x:Key="PagePadding">18,16</Thickness>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="PageTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="ModeTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="SectionTitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource AccentColor}" />
                <Setter Property="CharacterSpacing" Value="0" />
                <Setter Property="TextTransform" Value="Uppercase" />
            </Style>
            <Style x:Key="MutedLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="TinyLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource MutedTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="MetricLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource AccentBlueColor}" />
            </Style>
            <Style x:Key="ChipLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource AccentColor}" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
            </Style>
            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource PanelColor}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Stroke" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="8" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="CompactPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="Padding" Value="12" />
            </Style>
            <Style x:Key="ActionCardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Stroke" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="8" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="StatusPillBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ChipBackgroundColor}" />
                <Setter Property="Padding" Value="9,4" />
                <Setter Property="Stroke" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="8" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="BackgroundColor" Value="{StaticResource PanelRaisedColor}" />
                <Setter Property="BorderColor" Value="{StaticResource PanelBorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#7C3AED" />
                <Setter Property="BorderColor" Value="#A78BFA" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="#FFFFFF" />
            </Style>
            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#2A0B0B" />
                <Setter Property="BorderColor" Value="{StaticResource DangerColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource DangerColor}" />
            </Style>
            <Style x:Key="BrightButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#152515" />
                <Setter Property="BorderColor" Value="{StaticResource AccentGreenColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource AccentGreenColor}" />
            </Style>
            <Style x:Key="NeonBlueButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#071827" />
                <Setter Property="BorderColor" Value="{StaticResource AccentBlueColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor" Value="{StaticResource AccentBlueColor}" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
            </Style>
            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedTextColor}" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="TitleColor" Value="{StaticResource SecondaryTextColor}" />
            </Style>
            <Style TargetType="Slider">
                <Setter Property="ThumbColor" Value="{StaticResource AccentColor}" />
                <Setter Property="MinimumTrackColor" Value="{StaticResource AccentBlueColor}" />
                <Setter Property="MaximumTrackColor" Value="{StaticResource PanelBorderColor}" />
            </Style>
            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="{StaticResource AccentGreenColor}" />
                <Setter Property="ThumbColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
